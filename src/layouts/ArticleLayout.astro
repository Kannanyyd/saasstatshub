---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import TOC from '../components/TOC.astro';
import QuickOverview from '../components/QuickOverview.astro';
import KeyTakeaways from '../components/KeyTakeaways.astro';
import Sources from '../components/Sources.astro';
import Newsletter from '../components/Newsletter.astro';
import CoverImage from '../components/CoverImage.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import FaqSection from '../components/FaqSection.astro';
import { metaFor } from '../lib/constants';
import { buildDatasetSchema } from '../lib/dataset-schema';
import { buildFaqPageSchema } from '../lib/faq-schema';
import type { ArticleCard } from '../lib/wp-api';
import type { FaqItem } from '../lib/faq-schema';

interface OverviewItem {
  label: string;
  value: string;
}

interface Source {
  name: string;
  title: string;
  date?: string;
  url?: string;
}

interface TocItem {
  id: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  datePublished: string;
  dateModified?: string;
  readTime: string;
  category: string;
  categorySlug: string;
  overviewItems?: OverviewItem[];
  takeaways?: string[];
  sources?: Source[];
  tocItems?: TocItem[];
  ogImage?: string;
  /** Phase 2.1: focus-keywords pass-through for Dataset.keywords. */
  focusKeywords?: string;
  /** Phase 2.1: lastUpdated pass-through for Dataset.temporalCoverage. */
  lastUpdated?: string;
  /** Phase 2.1: resolved Related Articles tiles (3 or 4 entries; <3 → don't render). */
  relatedTiles?: ArticleCard[];
  /** Phase 2.2: FAQ items for Schema.org FAQPage + visible accordion. */
  faqItems?: FaqItem[];
}

const {
  title,
  description,
  datePublished,
  dateModified,
  readTime,
  category,
  categorySlug,
  overviewItems = [],
  takeaways = [],
  sources = [],
  tocItems = [],
  ogImage,
  focusKeywords = '',
  lastUpdated = '',
  relatedTiles = [],
  faqItems = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const siteOrigin = Astro.site ? Astro.site.origin : 'https://saasstatshub.com';
const categoryUrl = `${siteOrigin}/categories/${categorySlug}/`;

// Schema.org Article (full Article schema for Google Rich Results)
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  datePublished,
  dateModified: dateModified || datePublished,
  author: {
    "@type": "Organization",
    name: "SaaSStatsHub",
    url: siteOrigin,
  },
  publisher: {
    "@type": "Organization",
    name: "SaaSStatsHub",
    url: siteOrigin,
    logo: {
      "@type": "ImageObject",
      url: `${siteOrigin}/og-default.svg`,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalURL,
  },
  url: canonicalURL,
  ...(ogImage
    ? {
        image: {
          "@type": "ImageObject",
          url: ogImage.startsWith('http') ? ogImage : `${siteOrigin}${ogImage}`,
        },
      }
    : {
        image: {
          "@type": "ImageObject",
          url: `${siteOrigin}/og-default.svg`,
        },
      }),
  inLanguage: 'en-US',
  isAccessibleForFree: true,
  articleSection: category,
};

// Schema.org BreadcrumbList
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteOrigin}/` },
    { "@type": "ListItem", position: 2, name: category, item: categoryUrl },
    { "@type": "ListItem", position: 3, name: title, item: canonicalURL },
  ],
};

// Phase 2.1: Schema.org Dataset (third JSON-LD block, after Article + BreadcrumbList)
const datasetSchema = buildDatasetSchema({
  title,
  cleanExcerpt: description,
  canonicalURL,
  siteOrigin,
  focusKeywords,
  lastUpdated,
  quickOverview: overviewItems.map((it) => ({ statLabel: it.label, statValue: it.value })),
});

// Phase 2.1: resolve category icon for the breadcrumb (Req 2.5, 2.12)
const categoryMeta = metaFor(category, categorySlug);

// Phase 2.2: build FAQPage JSON-LD (may be null if no valid FAQ items)
const faqPageSchema = buildFaqPageSchema(faqItems);

// Phase C-1 follow-up: detect affiliate-bearing articles to inject FTC-compliant
// disclosure prominently above-the-fold (BaseLayout footer link is not enough).
//
// An article is treated as affiliate-bearing when ALL of:
//   1. The category is one of the 8 commercial-intent slugs that hold paid links.
//   2. The URL slug looks like a comparison ("…-vs-…") or a buyer's guide
//      ("best-…"), excluding the few "…-statistics-2026" stat pages that
//      happen to contain "-vs-" in the title.
//
// Keep this list in sync with the categories that surface affiliate CTAs in the
// article body and the bottom recommendations block below.
const AFFILIATE_CATEGORIES = new Set([
  'crm',
  'marketing',
  'ecommerce',
  'project-management',
  'hr',
  'communication',
  'analytics',
  'security',
  'finance',
  'ai',
  'devops',
  'sales',
]);
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const articleSlug = pathSegments[pathSegments.length - 1] || '';
const isStatisticsPost =
  articleSlug.includes('-statistics-') || articleSlug.endsWith('-statistics');
const isComparison = articleSlug.includes('-vs-') && !isStatisticsPost;
const isBuyersGuide = articleSlug.startsWith('best-');
const hasAffiliateLinks =
  AFFILIATE_CATEGORIES.has(categorySlug) && (isComparison || isBuyersGuide);

// Phase C-1 follow-up: auto-suggest a related affiliate-style read at the
// bottom of every commercial article so readers always have a next step.
// For comparison posts we point to the category buyer's guide; for buyer's
// guides we point to the category landing page (which lists every comparison).
let relatedRecommendation: { href: string; label: string; kind: 'guide' | 'category' } | null = null;
if (hasAffiliateLinks) {
  if (isComparison) {
    relatedRecommendation = {
      href: `/categories/${categorySlug}/`,
      label: `See all ${category} buyer's guides & comparisons`,
      kind: 'category',
    };
  } else if (isBuyersGuide) {
    relatedRecommendation = {
      href: `/categories/${categorySlug}/`,
      label: `Browse more ${category} comparisons & data`,
      kind: 'category',
    };
  }
}
---

<BaseLayout title={title} description={description} canonicalURL={canonicalURL} ogImage={ogImage} ogType="article">
  {/* Article-specific meta tags for social and search engines.
      Previously missing — only JSON-LD Article schema was present, but
      Google and Facebook also look for these HTML meta tags.
      Injected into BaseLayout's <head> via the named "head" slot. */}
  <Fragment slot="head">
    {datePublished && (
      <meta property="article:published_time" content={datePublished} />
    )}
    {dateModified && (
      <meta property="article:modified_time" content={dateModified} />
    )}
    <meta property="article:author" content="SaaSStatsHub" />
    <meta property="article:section" content={category} />
    <meta name="author" content="SaaSStatsHub" />
  </Fragment>

  <!-- Reading progress bar -->
  <div id="reading-progress" aria-hidden="true"
       class="fixed left-0 top-16 right-0 h-[2px] origin-left z-40 bg-gradient-to-r from-cyan-400 via-blue-500 to-violet-500"
       style="transform: scaleX(0); transition: transform 80ms linear;"></div>

  <!-- Structured Data: Article → BreadcrumbList → Dataset → FAQPage (Req 3.14, 2.8) -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(datasetSchema)} />
  {faqPageSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />
  )}

  <div class="max-w-[1200px] mx-auto px-6 py-8">
    <!-- Breadcrumb (Phase 2.1: category crumb gets a Lucide icon) -->
    <Breadcrumb crumbs={[
      { label: 'Home', href: '/' },
      { label: category, href: `/categories/${categorySlug}/`, iconName: categoryMeta.iconName },
      { label: title },
    ]} />

    <div class="flex gap-8">
      <!-- Main Content -->
      <article class="article-content flex-1 min-w-0" data-pagefind-body>
        <!-- Title -->
        <h1 class="font-display-lg text-3xl md:text-4xl font-bold mb-4" data-pagefind-meta="title">{title}</h1>
        <div class="flex items-center gap-4 text-sm text-text-muted mb-6">
          <span>Updated: {new Date(dateModified || datePublished).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          <span>·</span>
          <span>{readTime} read</span>
          <span>·</span>
          <a href={`/categories/${categorySlug}/`} class="text-primary font-semibold" data-pagefind-filter="category">{category}</a>
        </div>

        <!--
          Affiliate disclosure (FTC 16 CFR 255 + Google "sneaky" content guideline).
          Must appear ABOVE any affiliate link, in clear and conspicuous text — a
          footer-only link is not considered prominent. Rendered only on
          comparison/buyer's-guide articles in commercial categories.
        -->
        {hasAffiliateLinks && (
          <aside
            class="mb-8 px-4 py-3 rounded-lg border border-border bg-bg-alt/60 text-sm text-text-secondary leading-relaxed"
            role="note"
            aria-label="Affiliate disclosure"
          >
            <strong class="text-text">Disclosure:</strong> This page contains
            affiliate links. We may earn a commission if you sign up through our
            links — at no extra cost to you. We only recommend tools we have
            researched against the {' '}
            <a href="/categories/" class="underline text-primary hover:text-primary-dark">130+ SaaS reports</a>
            {' '}we cite across the site. {' '}
            <a href="/affiliate-disclosure/" class="underline text-primary hover:text-primary-dark">
              Read our full disclosure
            </a>.
          </aside>
        )}

        <!-- Cover image -->
        <div class="aspect-[16/9] rounded-xl overflow-hidden mb-8 shadow-sm border border-border">
          <CoverImage title={title} category={category} />
        </div>

        <!-- Mobile TOC (only visible below md breakpoint) -->
        {tocItems.length > 0 && (
          <div class="md:hidden">
            <TOC items={tocItems} variant="mobile" />
          </div>
        )}

        <!-- Quick Overview -->
        {overviewItems.length > 0 && <QuickOverview items={overviewItems} />}

        <!-- Article Body -->
        <div class="article-body">
          <slot />
        </div>

        <!-- Key Takeaways (full article) -->
        {takeaways.length > 0 && <KeyTakeaways items={takeaways} />}

        <!-- Sources -->
        {sources.length > 0 && <Sources sources={sources} />}

        <!-- Phase 2.2: FAQ accordion (between Sources and Related Articles) -->
        {faqItems.length > 0 && <FaqSection items={faqItems} />}

        <!-- Phase 2.1: Related Articles (between Sources and bottom Newsletter) -->
        {relatedTiles.length >= 3 && <RelatedArticles tiles={relatedTiles} />}

        <!-- Signals subsite CTA -->
        <aside class="mt-8 p-5 rounded-xl border border-border bg-bg-alt/40">
          <div class="flex items-start gap-3">
            <div class="text-2xl shrink-0" aria-hidden="true">📡</div>
            <div class="flex-1">
              <p class="text-xs text-text-muted uppercase tracking-widest font-mono mb-1.5">
                Looking for rising opportunities?
              </p>
              <h3 class="text-lg font-bold mb-2">Track this topic on Signals</h3>
              <p class="text-sm text-text-secondary leading-relaxed mb-3">
                Beyond statistics, <strong class="text-text">SaaSStatsHub Signals</strong> tracks
                rising keywords across Hacker News, GitHub, and Google Trends — and tells you
                what kind of website you could build around them. Free, updated daily.
              </p>
              <a
                href="https://signals.saasstatshub.com/"
                class="inline-flex items-center gap-1 text-sm font-semibold text-primary hover:text-primary-dark"
                rel="noopener"
              >
                Explore SaaSStatsHub Signals
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </aside>

        <!-- Calculator CTA (Phase C-1 T1) — show on commerce/SaaS-metric relevant categories -->
        {['crm', 'marketing', 'analytics', 'ecommerce', 'project-management'].includes(categorySlug) && (
          <aside class="mt-4 p-5 rounded-xl border border-border bg-bg-alt/40">
            <div class="flex items-start gap-3">
              <div class="text-2xl shrink-0" aria-hidden="true">🧮</div>
              <div class="flex-1">
                <p class="text-xs text-text-muted uppercase tracking-widest font-mono mb-1.5">
                  Free tool
                </p>
                <h3 class="text-lg font-bold mb-2">Calculate your own SaaS metrics</h3>
                <p class="text-sm text-text-secondary leading-relaxed mb-3">
                  Plug in your MRR, CAC, and churn — get instant ARR, LTV, payback period, and a
                  24-month forecast. Compare your numbers against industry benchmarks from
                  <strong class="text-text">130+ SaaS reports</strong>.
                </p>
                <a
                  href="/saas-pricing-calculator/"
                  class="inline-flex items-center gap-1 text-sm font-semibold text-primary hover:text-primary-dark"
                >
                  Open SaaS Pricing Calculator
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </aside>
        )}

        <!--
          Auto-injected related recommendation (Phase C-1 follow-up).
          Closes the loop: a comparison article points back to the category
          buyer's guide hub; a buyer's guide points back to all category
          comparisons. Keeps internal-link depth low and surfaces affiliate
          paths without manually editing each post body.
        -->
        {relatedRecommendation && (
          <aside class="mt-4 p-5 rounded-xl border border-border bg-bg-alt/40">
            <div class="flex items-start gap-3">
              <div class="text-2xl shrink-0" aria-hidden="true">🧭</div>
              <div class="flex-1">
                <p class="text-xs text-text-muted uppercase tracking-widest font-mono mb-1.5">
                  Keep exploring
                </p>
                <h3 class="text-lg font-bold mb-2">
                  {isComparison ? 'Still comparing options?' : 'Want a deeper comparison?'}
                </h3>
                <p class="text-sm text-text-secondary leading-relaxed mb-3">
                  {isComparison
                    ? `We've ranked the top ${category} tools side-by-side with pricing, fit, and trade-offs — pulled from our underlying SaaS reports.`
                    : `See head-to-head matchups for the ${category} tools listed above, with pricing data and migration friction.`}
                </p>
                <a
                  href={relatedRecommendation.href}
                  class="inline-flex items-center gap-1 text-sm font-semibold text-primary hover:text-primary-dark"
                >
                  {relatedRecommendation.label}
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </aside>
        )}

        <!-- Bottom Newsletter -->
        <div class="mt-8">
          <Newsletter />
        </div>
      </article>

      <!-- Desktop Sidebar -->
      <aside class="hidden md:block w-[340px] shrink-0">
        <div class="sticky top-20 space-y-6">
          {tocItems.length > 0 && <TOC items={tocItems} variant="desktop" />}
          <Newsletter />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
