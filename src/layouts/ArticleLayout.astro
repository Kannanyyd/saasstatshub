---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import TOC from '../components/TOC.astro';
import QuickOverview from '../components/QuickOverview.astro';
import KeyTakeaways from '../components/KeyTakeaways.astro';
import Sources from '../components/Sources.astro';
import Newsletter from '../components/Newsletter.astro';
import CoverImage from '../components/CoverImage.astro';

interface OverviewItem {
  label: string;
  value: string;
}

interface Source {
  name: string;
  title: string;
  date?: string;
  url?: string;
}

interface TocItem {
  id: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  datePublished: string;
  dateModified?: string;
  readTime: string;
  category: string;
  categorySlug: string;
  overviewItems?: OverviewItem[];
  takeaways?: string[];
  sources?: Source[];
  tocItems?: TocItem[];
  ogImage?: string;
}

const {
  title,
  description,
  datePublished,
  dateModified,
  readTime,
  category,
  categorySlug,
  overviewItems = [],
  takeaways = [],
  sources = [],
  tocItems = [],
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const siteOrigin = Astro.site ? Astro.site.origin : 'https://saasstatshub.com';
const categoryUrl = `${siteOrigin}/categories/${categorySlug}/`;

// Schema.org Article (full Article schema for Google Rich Results)
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  datePublished,
  dateModified: dateModified || datePublished,
  author: {
    "@type": "Organization",
    name: "SaaSStatsHub",
    url: siteOrigin,
  },
  publisher: {
    "@type": "Organization",
    name: "SaaSStatsHub",
    url: siteOrigin,
    logo: {
      "@type": "ImageObject",
      url: `${siteOrigin}/og-default.svg`,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalURL,
  },
  url: canonicalURL,
  ...(ogImage
    ? {
        image: {
          "@type": "ImageObject",
          url: ogImage.startsWith('http') ? ogImage : `${siteOrigin}${ogImage}`,
        },
      }
    : {
        image: {
          "@type": "ImageObject",
          url: `${siteOrigin}/og-default.svg`,
        },
      }),
  inLanguage: 'en-US',
  isAccessibleForFree: true,
  articleSection: category,
};

// Schema.org BreadcrumbList
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteOrigin}/` },
    { "@type": "ListItem", position: 2, name: category, item: categoryUrl },
    { "@type": "ListItem", position: 3, name: title, item: canonicalURL },
  ],
};
---

<BaseLayout title={title} description={description} canonicalURL={canonicalURL} ogImage={ogImage} ogType="article">
  <slot name="head" />

  <!-- Reading progress bar -->
  <div id="reading-progress" aria-hidden="true"
       class="fixed left-0 top-16 right-0 h-[2px] origin-left z-40 bg-gradient-to-r from-cyan-400 via-blue-500 to-violet-500"
       style="transform: scaleX(0); transition: transform 80ms linear;"></div>

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="max-w-[1200px] mx-auto px-6 py-8">
    <!-- Breadcrumb -->
    <Breadcrumb crumbs={[
      { label: 'Home', href: '/' },
      { label: category, href: `/categories/${categorySlug}/` },
      { label: title },
    ]} />

    <div class="flex gap-8">
      <!-- Main Content -->
      <article class="article-content flex-1 min-w-0" data-pagefind-body>
        <!-- Title -->
        <h1 class="font-display-lg text-3xl md:text-4xl font-bold mb-4" data-pagefind-meta="title">{title}</h1>
        <div class="flex items-center gap-4 text-sm text-text-muted mb-6">
          <span>Updated: {dateModified || datePublished}</span>
          <span>·</span>
          <span>{readTime} read</span>
          <span>·</span>
          <a href={`/categories/${categorySlug}/`} class="text-primary font-semibold" data-pagefind-filter="category">{category}</a>
        </div>

        <!-- Cover image -->
        <div class="aspect-[16/9] rounded-xl overflow-hidden mb-8 shadow-sm border border-border">
          <CoverImage title={title} category={category} />
        </div>

        <!-- Mobile TOC -->
        {tocItems.length > 0 && <TOC items={tocItems} />}

        <!-- Quick Overview -->
        {overviewItems.length > 0 && <QuickOverview items={overviewItems} />}

        <!-- Article Body -->
        <div class="article-body">
          <slot />
        </div>

        <!-- Key Takeaways (full article) -->
        {takeaways.length > 0 && <KeyTakeaways items={takeaways} />}

        <!-- Sources -->
        {sources.length > 0 && <Sources sources={sources} />}

        <!-- Bottom Newsletter -->
        <div class="mt-8">
          <Newsletter />
        </div>
      </article>

      <!-- Desktop Sidebar -->
      <aside class="hidden md:block w-[340px] shrink-0">
        <div class="sticky top-20 space-y-6">
          {tocItems.length > 0 && <TOC items={tocItems} />}
          <Newsletter />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
