---
import { CATEGORIES } from '../lib/constants';
import SearchModal from '../components/SearchModal.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  canonicalURL,
  ogImage,
  ogType = 'website',
} = Astro.props;

const siteName = 'SaaSStatsHub';
const fullTitle = title === 'Home' ? `${siteName} — The #1 Source for SaaS Statistics & Data` : `${title} | ${siteName}`;

// Resolve absolute URLs for social card metadata.
const pageUrl = canonicalURL || new URL(Astro.url.pathname, Astro.site).href;
const defaultOg = new URL('/og-default.svg', Astro.site).href;
const ogImageAbs = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href)
  : defaultOg;

const siteOrigin = Astro.site ? Astro.site.origin : 'https://saasstatshub.com';
const isHomepage = Astro.url.pathname === '/' || Astro.url.pathname === '';

// Schema.org WebSite (homepage only) — enables Google sitelinks search box
const websiteSchema = isHomepage
  ? {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: siteName,
      url: siteOrigin,
      description,
      inLanguage: 'en-US',
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: `${siteOrigin}/?q={search_term_string}`,
        },
        "query-input": "required name=search_term_string",
      },
    }
  : null;

// Schema.org Organization (every page) — links the brand for knowledge graph
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteName,
  url: siteOrigin,
  logo: `${siteOrigin}/og-default.svg`,
  description,
};

// Google Analytics 4 — Measurement ID is public (not a secret).
// Override per-environment via PUBLIC_GA_ID if needed; falls back to
// the production ID below.
const gaId =
  (import.meta.env.PUBLIC_GA_ID as string | undefined) || 'G-Z95ZVJ8TK6';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    <link rel="canonical" href={pageUrl} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImageAbs} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- Google Fonts: Inter + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Sitemap & feed discovery -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Google AdSense site verification (Account ID, not an ad unit) -->
    <meta name="google-adsense-account" content="ca-pub-5320191709518848" />

    <!--
      Google Consent Mode v2 — set defaults BEFORE GA / AdSense loads.
      Defaults are "denied" until the user accepts via the cookie banner.
      The banner script (in CookieConsent.astro) updates these to
      "granted" if/when the user clicks "Accept all".
    -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      window.gtag = gtag;
      // Restore previously-stored consent so returning visitors don't lose their choice.
      try {
        var stored = localStorage.getItem('saasstatshub_cookie_consent');
        var allGranted = stored === 'all';
        gtag('consent', 'default', {
          ad_storage: allGranted ? 'granted' : 'denied',
          ad_user_data: allGranted ? 'granted' : 'denied',
          ad_personalization: allGranted ? 'granted' : 'denied',
          analytics_storage: allGranted ? 'granted' : 'denied',
          functionality_storage: 'granted',
          security_storage: 'granted',
          wait_for_update: 500,
        });
      } catch (e) {
        gtag('consent', 'default', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          analytics_storage: 'denied',
          functionality_storage: 'granted',
          security_storage: 'granted',
          wait_for_update: 500,
        });
      }
    </script>

    <!-- Google Analytics 4 -->
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          gtag('js', new Date());
          gtag('config', gaId, {
            anonymize_ip: true,
            send_page_view: true,
          });
        </script>
      </>
    )}

    <!-- Schema.org Organization (all pages) -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    {/* Schema.org WebSite (homepage only) — enables Google sitelinks search box */}
    {websiteSchema && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-50 glass border-b border-border/60" style="height: 64px; display: flex; align-items: center;">
      <div class="w-full max-w-[1200px] mx-auto px-6 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 no-underline group">
          <svg width="34" height="34" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="transition-transform duration-300 group-hover:scale-110">
            <defs>
              <linearGradient id="logo-grad" x1="4" y1="28" x2="28" y2="4" gradientUnits="userSpaceOnUse">
                <stop stop-color="#1E40AF"/>
                <stop offset="0.5" stop-color="#2563EB"/>
                <stop offset="1" stop-color="#7C3AED"/>
              </linearGradient>
            </defs>
            <rect x="4" y="18" width="6" height="10" rx="2" fill="url(#logo-grad)"/>
            <rect x="13" y="10" width="6" height="18" rx="2" fill="url(#logo-grad)" opacity="0.85"/>
            <rect x="22" y="4" width="6" height="24" rx="2" fill="#10B981"/>
          </svg>
          <span class="font-extrabold text-lg tracking-tight">
            <span class="text-text">SaaS</span><span class="gradient-text-primary">Stats</span><span class="text-text">Hub</span>
          </span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
          <div class="relative group">
            <button class="flex items-center gap-1.5 font-semibold text-sm text-text-secondary hover:text-primary transition-colors px-3 py-2 rounded-lg hover:bg-primary-lighter" aria-expanded="false">
              Categories
              <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="absolute top-full right-0 mt-1 w-[480px] bg-white border border-border rounded-xl shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 overflow-hidden">
              <div class="grid grid-cols-2 gap-0.5 p-2">
                {CATEGORIES.map((cat) => (
                  <a
                    href={`/categories/${cat.slug}/`}
                    class="flex items-center gap-2.5 px-3 py-2 text-[13px] text-text-secondary hover:text-primary hover:bg-primary-lighter rounded-lg transition-colors whitespace-nowrap"
                  >
                    <span class="w-7 h-7 inline-flex items-center justify-center rounded-md bg-primary-lighter text-base shrink-0">{cat.emoji}</span>
                    {cat.name}
                  </a>
                ))}
              </div>
            </div>
          </div>
          <a href="/about/" class="font-semibold text-sm text-text-secondary hover:text-primary transition-colors px-3 py-2 rounded-lg hover:bg-primary-lighter">About</a>
          <button id="search-toggle" class="p-2.5 text-text-secondary hover:text-primary transition-colors rounded-lg hover:bg-primary-lighter" aria-label="Search">
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </button>
        </nav>

        <!-- Mobile Hamburger -->
        <button id="mobile-menu-toggle" class="md:hidden p-2 text-text-secondary hover:text-primary transition-colors" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden absolute top-16 inset-x-0 bg-white border-b border-border shadow-lg z-40">
        <nav class="max-w-[1200px] mx-auto px-6 py-4 flex flex-col gap-1">
          {CATEGORIES.map((cat) => (
            <a
              href={`/categories/${cat.slug}/`}
              class="flex items-center gap-2 text-sm text-text-secondary hover:text-primary py-2 px-3 rounded-lg hover:bg-primary-lighter"
            >
              <span>{cat.emoji}</span>
              {cat.name}
            </a>
          ))}
          <hr class="border-border my-1" />
          <a href="/about/" class="text-sm text-text-secondary hover:text-primary py-2 px-3 rounded-lg hover:bg-primary-lighter">About</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-text text-white mt-16">
      <div class="max-w-[1200px] mx-auto px-6 pt-14 pb-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-10">
          <!-- Brand -->
          <div class="col-span-2 md:col-span-1">
            <div class="flex items-center gap-2.5 mb-3">
              <svg width="26" height="26" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="4" y="18" width="6" height="10" rx="2" fill="#3B82F6"/>
                <rect x="13" y="10" width="6" height="18" rx="2" fill="#60A5FA"/>
                <rect x="22" y="4" width="6" height="24" rx="2" fill="#10B981"/>
              </svg>
              <span class="font-extrabold text-base text-white">SaaSStatsHub</span>
            </div>
            <p class="text-sm text-gray-400 leading-relaxed">Comprehensive, up-to-date SaaS statistics — always cited.</p>
          </div>

          <!-- Categories -->
          <div>
            <h3 class="font-semibold text-xs text-gray-300 uppercase tracking-wider mb-3">Categories</h3>
            <ul class="space-y-2 text-sm">
              {CATEGORIES.slice(0, 5).map((cat) => (
                <li><a href={`/categories/${cat.slug}/`} class="text-gray-400 hover:text-white transition-colors">{cat.name}</a></li>
              ))}
            </ul>
          </div>

          <!-- Company -->
          <div>
            <h3 class="font-semibold text-xs text-gray-300 uppercase tracking-wider mb-3">Company</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/about/" class="text-gray-400 hover:text-white transition-colors">About</a></li>
              <li><a href="/contact/" class="text-gray-400 hover:text-white transition-colors">Contact</a></li>
              <li><a href="/write-for-us/" class="text-gray-400 hover:text-white transition-colors">Write for Us</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h3 class="font-semibold text-xs text-gray-300 uppercase tracking-wider mb-3">Legal</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="/privacy-policy/" class="text-gray-400 hover:text-white transition-colors">Privacy Policy</a></li>
              <li><a href="/terms-of-service/" class="text-gray-400 hover:text-white transition-colors">Terms of Service</a></li>
              <li><a href="/affiliate-disclosure/" class="text-gray-400 hover:text-white transition-colors">Affiliate Disclosure</a></li>
            </ul>
          </div>
        </div>

        <div class="pt-6 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-3">
          <p class="text-xs text-gray-500">&copy; 2026 SaaSStatsHub. All rights reserved.</p>
          <p class="text-xs text-gray-500">Built for data-driven decisions.</p>
        </div>
      </div>
    </footer>

    <SearchModal />
    <CookieConsent />

    <script>
      // Mobile menu toggle
      const mobileToggle = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      if (mobileToggle && mobileMenu) {
        mobileToggle.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });
      }

      // Search toggle is wired up by SearchModal.astro (data-search-trigger)

      // ===== Newsletter form submission =====
      // Hooks every <form class="newsletter-form"> on the page.
      // Submits to /api/subscribe and shows inline success/error feedback.
      const newsletterForms = document.querySelectorAll<HTMLFormElement>('.newsletter-form');
      newsletterForms.forEach((form) => {
        const input = form.querySelector<HTMLInputElement>('input[type="email"]');
        const honeypot = form.querySelector<HTMLInputElement>('input[name="hp"]');
        const submit = form.querySelector<HTMLButtonElement>('.newsletter-submit');
        const label = form.querySelector<HTMLElement>('.newsletter-submit-label');
        // Message element may live inside or just outside the form (sidebar vs CTA layout)
        const message =
          form.querySelector<HTMLElement>('.newsletter-message') ||
          form.parentElement?.querySelector<HTMLElement>('.newsletter-message') ||
          null;
        const source = form.dataset.newsletterSource || 'unknown';

        if (!input || !submit) return;

        const originalLabel = label?.textContent ?? 'Subscribe';

        function setMessage(text: string, kind: 'success' | 'error' | '') {
          if (!message) return;
          message.textContent = text;
          message.classList.remove('text-emerald-400', 'text-emerald-500', 'text-red-500', 'text-rose-400');
          if (kind === 'success') {
            // Pick contrast-appropriate color based on background tone
            const onDark = form.closest('.bg-gradient-to-br, [style*="linear-gradient"]') !== null;
            message.classList.add(onDark ? 'text-emerald-400' : 'text-emerald-500');
          } else if (kind === 'error') {
            const onDark = form.closest('.bg-gradient-to-br, [style*="linear-gradient"]') !== null;
            message.classList.add(onDark ? 'text-rose-400' : 'text-red-500');
          }
        }

        function setBusy(busy: boolean) {
          if (!submit) return;
          submit.disabled = busy;
          if (label) label.textContent = busy ? 'Subscribing…' : originalLabel;
        }

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          if (!input || !submit) return;

          const email = input.value.trim();
          if (!email) {
            setMessage('Please enter your email.', 'error');
            input.focus();
            return;
          }

          setMessage('', '');
          setBusy(true);

          try {
            const res = await fetch('/api/subscribe', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({
                email,
                source,
                hp: honeypot?.value ?? '',
              }),
            });
            const data: { ok?: boolean; error?: string; status?: string } = await res.json().catch(() => ({}));

            if (res.ok && data.ok) {
              if (data.status === 'already_subscribed') {
                setMessage("You're already on the list — thanks!", 'success');
              } else {
                setMessage('Thanks! Check your inbox to confirm.', 'success');
              }
              input.value = '';
            } else {
              setMessage(data.error || 'Subscription failed. Please try again.', 'error');
            }
          } catch {
            setMessage('Network error. Please try again.', 'error');
          } finally {
            setBusy(false);
          }
        });
      });

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ===== Spotlight follow on cards =====
      const spotlightTargets = document.querySelectorAll<HTMLElement>('.article-card, .category-card, .bg-spotlight-dark');
      spotlightTargets.forEach((el) => {
        el.addEventListener('pointermove', (e) => {
          const rect = el.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / rect.width) * 100;
          const y = ((e.clientY - rect.top) / rect.height) * 100;
          el.style.setProperty('--mx', `${x}%`);
          el.style.setProperty('--my', `${y}%`);
        });
        el.addEventListener('pointerleave', () => {
          el.style.setProperty('--mx', `50%`);
          el.style.setProperty('--my', `0%`);
        });
      });

      // ===== Count-up animation =====
      // Reads target value from element text (e.g. "$232B", "14.2%", "30,000+", "12,400")
      // Parses to number, animates from 0, preserves prefix/suffix.
      function parseStat(input: string): { prefix: string; suffix: string; value: number; decimals: number } {
        const match = input.match(/^([^\d-]*)([\d,.]+)(.*)$/);
        if (!match) return { prefix: '', suffix: input, value: 0, decimals: 0 };
        const [, prefix, num, suffix] = match;
        const cleaned = num.replace(/,/g, '');
        const value = parseFloat(cleaned);
        const decimals = (cleaned.split('.')[1] || '').length;
        return { prefix, suffix, value: isNaN(value) ? 0 : value, decimals };
      }

      function formatNumber(value: number, decimals: number): string {
        return value.toLocaleString('en-US', {
          minimumFractionDigits: decimals,
          maximumFractionDigits: decimals,
        });
      }

      const countUpEls = document.querySelectorAll<HTMLElement>('[data-count-up]');
      if (countUpEls.length > 0 && !prefersReducedMotion) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            const original = el.dataset.target || el.textContent || '';
            if (!el.dataset.target) el.dataset.target = original;
            const { prefix, suffix, value, decimals } = parseStat(el.dataset.target);
            const duration = 1200;
            const start = performance.now();
            function tick(now: number) {
              const t = Math.min(1, (now - start) / duration);
              // easeOutCubic
              const eased = 1 - Math.pow(1 - t, 3);
              const current = value * eased;
              el.textContent = `${prefix}${formatNumber(current, decimals)}${suffix}`;
              if (t < 1) requestAnimationFrame(tick);
              else el.textContent = `${prefix}${formatNumber(value, decimals)}${suffix}`;
            }
            requestAnimationFrame(tick);
            observer.unobserve(el);
          });
        }, { threshold: 0.4 });
        countUpEls.forEach((el) => {
          // Stash target before zeroing so we can re-render
          const original = el.textContent || '';
          el.dataset.target = original;
          const { prefix, suffix, decimals } = parseStat(original);
          el.textContent = `${prefix}${formatNumber(0, decimals)}${suffix}`;
          observer.observe(el);
        });
      }

      // ===== Typewriter (data-typewriter) =====
      const typewriterEls = document.querySelectorAll<HTMLElement>('[data-typewriter]');
      typewriterEls.forEach((el) => {
        const fallback = [
          'Always cited. Always current.',
          'Power your decisions with data.',
          '$232B market. 30,000+ companies. 1 source.',
        ];
        let phrases: string[] = fallback;
        if (el.dataset.phrases) {
          try {
            const parsed = JSON.parse(el.dataset.phrases);
            if (Array.isArray(parsed) && parsed.length > 0) {
              phrases = parsed.filter((p) => typeof p === 'string' && p.length > 0);
              if (phrases.length === 0) phrases = fallback;
            }
          } catch {
            phrases = fallback;
          }
        }
        if (prefersReducedMotion) {
          el.textContent = phrases[0];
          return;
        }
        let phraseIndex = 0;
        let charIndex = 0;
        let deleting = false;
        el.parentElement?.classList.add('type-caret');

        function step() {
          const current = phrases[phraseIndex];
          if (!deleting) {
            charIndex++;
            el.textContent = current.slice(0, charIndex);
            if (charIndex === current.length) {
              deleting = true;
              setTimeout(step, 2200);
              return;
            }
            setTimeout(step, 45 + Math.random() * 35);
          } else {
            charIndex--;
            el.textContent = current.slice(0, charIndex);
            if (charIndex === 0) {
              deleting = false;
              phraseIndex = (phraseIndex + 1) % phrases.length;
              setTimeout(step, 350);
              return;
            }
            setTimeout(step, 22);
          }
        }
        setTimeout(step, 600);
      });

      // ===== Reading progress bar (article pages) =====
      const progressBar = document.getElementById('reading-progress');
      if (progressBar) {
        const onScroll = () => {
          const h = document.documentElement;
          const scrollable = h.scrollHeight - h.clientHeight;
          const ratio = scrollable > 0 ? Math.min(1, h.scrollTop / scrollable) : 0;
          progressBar.style.transform = `scaleX(${ratio})`;
        };
        document.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      // ===== TOC active section highlight =====
      const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc a[href^="#"]');
      if (tocLinks.length > 0) {
        const idMap = new Map<string, HTMLAnchorElement>();
        tocLinks.forEach((a) => {
          const id = a.getAttribute('href')?.slice(1);
          if (id) idMap.set(id, a);
        });
        const headings = Array.from(idMap.keys())
          .map((id) => document.getElementById(id))
          .filter((el): el is HTMLElement => !!el);
        if (headings.length > 0) {
          const tocObserver = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                const id = entry.target.id;
                const link = idMap.get(id);
                if (!link) return;
                if (entry.isIntersecting) {
                  tocLinks.forEach((l) => l.classList.remove('active'));
                  link.classList.add('active');
                }
              });
            },
            { rootMargin: '-30% 0px -60% 0px', threshold: 0 }
          );
          headings.forEach((h) => tocObserver.observe(h));
        }
      }
    </script>
  </body>
</html>
