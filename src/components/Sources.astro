---
import Icon from './Icon.astro';

interface Source {
  name: string;
  title: string;
  date?: string;
  url?: string;
}

interface Props {
  sources: Source[];
}

const { sources } = Astro.props;
---

<div class="mt-8">
  <h2 class="text-lg font-bold mb-3">Sources</h2>
  <ol class="sources-list list-decimal pl-5">
    {sources.map((s) => (
      <li>
        {s.url ? (
          <a href={s.url} target="_blank" rel="noopener noreferrer">
            {s.name}
            <Icon name="external-link" aria-hidden="true" class="inline-block w-3 h-3 ml-1 align-baseline" />
          </a>
        ) : (
          s.name
        )}
        , &ldquo;{s.title}&rdquo;{s.date ? `, ${s.date}` : ''}
      </li>
    ))}
  </ol>
</div>
