---
/**
 * CookieConsent — minimal GDPR/CCPA-compatible cookie consent banner.
 *
 * Consent Mode v2 defaults (denied) are set by BaseLayout *before* GA loads.
 * This component only handles:
 *   1. Showing the banner if no prior choice exists
 *   2. Updating Consent Mode and persisting the choice when user clicks
 *
 * Storage:
 *   - localStorage key: `saasstatshub_cookie_consent`
 *   - mirrored cookie of the same name (6-month expiry, SameSite=Lax)
 *   - values: 'all' | 'essential'
 */
import Icon from './Icon.astro';
---

<div
  id="cookie-consent"
  class="hidden fixed bottom-4 left-4 right-4 md:left-auto md:right-6 md:bottom-6 md:max-w-md z-[200] rounded-2xl border border-cyan-300/20 shadow-2xl"
  role="dialog"
  aria-modal="false"
  aria-labelledby="cookie-consent-title"
  style="background: linear-gradient(180deg, rgba(15,23,42,0.97), rgba(15,23,42,0.99));"
>
  <button
    type="button"
    data-cookie-action="reject"
    aria-label="Dismiss cookie banner"
    class="absolute top-3 right-3 p-1.5 text-blue-300/60 hover:text-white transition-colors rounded"
  >
    <Icon name="x" aria-hidden="true" class="w-4 h-4" />
  </button>
  <div class="p-5">
    <h2 id="cookie-consent-title" class="text-white font-bold text-base mb-2 flex items-center gap-2">
      <span aria-hidden="true">🍪</span> We use cookies
    </h2>
    <p class="text-sm text-blue-200/75 leading-relaxed mb-4">
      Essential cookies keep this site running. With your consent, we also use Google Analytics
      (and, when enabled, Google AdSense). Change your choice any time on our
      <a href="/cookie-policy/" class="underline hover:text-white">Cookie Policy</a> page.
    </p>
    <div class="flex flex-col sm:flex-row gap-2">
      <button
        type="button"
        data-cookie-action="reject"
        class="flex-1 px-4 py-2.5 rounded-xl border border-white/15 text-sm font-medium text-blue-100 hover:bg-white/5 hover:border-white/25 transition-colors"
      >
        Reject non-essential
      </button>
      <button
        type="button"
        data-cookie-action="accept"
        class="flex-1 px-4 py-2.5 rounded-xl text-sm font-bold text-white gradient-primary hover:shadow-glow transition-all"
      >
        Accept all
      </button>
    </div>
    <p class="text-[11px] text-blue-300/50 mt-3 font-mono">
      Your choice is stored locally for 6 months.
    </p>
  </div>
</div>

<script is:inline>
  (function () {
    const KEY = 'saasstatshub_cookie_consent';
    const SIX_MONTHS = 60 * 60 * 24 * 180;
    const banner = document.getElementById('cookie-consent');
    if (!banner) return;

    function read() {
      try {
        return localStorage.getItem(KEY);
      } catch {
        const m = document.cookie.match(/(?:^|; )saasstatshub_cookie_consent=([^;]+)/);
        return m ? decodeURIComponent(m[1]) : null;
      }
    }

    function write(value) {
      try {
        localStorage.setItem(KEY, value);
      } catch {}
      document.cookie =
        'saasstatshub_cookie_consent=' +
        encodeURIComponent(value) +
        '; max-age=' +
        SIX_MONTHS +
        '; path=/; SameSite=Lax';
    }

    function applyConsent(value) {
      if (typeof window.gtag !== 'function') return;
      const granted = value === 'all';
      window.gtag('consent', 'update', {
        ad_storage: granted ? 'granted' : 'denied',
        ad_user_data: granted ? 'granted' : 'denied',
        ad_personalization: granted ? 'granted' : 'denied',
        analytics_storage: granted ? 'granted' : 'denied',
      });
    }

    const existing = read();
    if (existing !== 'all' && existing !== 'essential') {
      // Show banner shortly after page load
      setTimeout(() => banner.classList.remove('hidden'), 800);
    }

    banner.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;
      const action = target.getAttribute('data-cookie-action');
      if (!action) return;
      const value = action === 'accept' ? 'all' : 'essential';
      write(value);
      applyConsent(value);
      banner.classList.add('hidden');
    });
  })();
</script>
