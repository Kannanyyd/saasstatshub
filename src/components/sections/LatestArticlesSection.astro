---
import type { LatestArticlesSection } from '../../lib/site-config';
import type { ArticleCard as ArticleCardType } from '../../lib/wp-api';
import ArticleCard from '../ArticleCard.astro';

interface Props {
  section: LatestArticlesSection;
  articles: ArticleCardType[];
}

const { section, articles } = Astro.props;

if (articles.length === 0) {
  // No articles to show — render nothing rather than an empty grid.
}
---

{articles.length > 0 && (
  <section class="mt-14 md:mt-16">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="flex items-end justify-between mb-8">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <div class="w-8 h-1 rounded-full gradient-primary"></div>
            <span class="text-xs font-bold uppercase tracking-widest text-primary">{section.eyebrow || 'Latest'}</span>
          </div>
          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight">{section.heading || 'Fresh Insights & Data'}</h2>
        </div>
        {section.viewAllHref && (
          <a href={section.viewAllHref} class="hidden sm:flex items-center gap-1.5 text-sm font-semibold text-primary hover:text-primary-dark transition-colors group">
            View all
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        )}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 stagger-children">
        {articles.map((article) => (
          <div class="animate-fade-in-up">
            <ArticleCard
              title={article.title}
              slug={article.slug}
              excerpt={article.excerpt}
              date={article.date}
              readTime={`${article.readTime} min`}
              category={article.category.name}
              categorySlug={article.category.slug}
              image={article.image}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
)}
