---
/**
 * Homepage callout for the Free Tools section (Phase C-1 T1).
 * Sits below SignalsCalloutSection, above the newsletter CTA.
 *
 * Currently features a single tool (SaaS Pricing Calculator).
 * Layout supports adding more tools as they ship (T2 Churn / T3 Valuation).
 */

const calculatorUrl = '/saas-pricing-calculator/';
---

<section class="py-14 px-6">
  <div class="max-w-[1200px] mx-auto">
    <div
      class="relative overflow-hidden rounded-2xl border border-border p-8 md:p-12"
      style="background: linear-gradient(135deg, var(--color-bg-warm) 0%, var(--color-bg-alt) 100%);"
    >
      <!-- Decorative bar chart icon -->
      <svg
        class="absolute right-8 top-8 opacity-15 pointer-events-none hidden md:block"
        width="160"
        height="160"
        viewBox="0 0 160 160"
        aria-hidden="true"
      >
        <rect x="20" y="100" width="20" height="40" rx="3" fill="var(--color-primary)" />
        <rect x="50" y="70" width="20" height="70" rx="3" fill="var(--color-primary)" opacity="0.85" />
        <rect x="80" y="40" width="20" height="100" rx="3" fill="var(--color-primary)" opacity="0.7" />
        <rect x="110" y="20" width="20" height="120" rx="3" fill="var(--color-violet)" opacity="0.85" />
      </svg>

      <div class="relative max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-surface-elevated border border-border text-xs font-mono uppercase tracking-widest text-text-secondary mb-4">
          <span aria-hidden="true">🧮</span>
          Free tool
        </div>

        <h2 class="text-2xl md:text-3xl font-bold mb-3">
          Calculate your <span class="gradient-text-primary">SaaS metrics</span> in seconds
        </h2>

        <p class="text-text-secondary leading-relaxed mb-6">
          Plug in your MRR, churn, and CAC — get instant ARR, LTV, payback period, and 24-month
          forecast. Compare your numbers against benchmarks from <strong class="text-text">130+ SaaS
          industry reports</strong>. Export as CSV or PDF, or embed it on your blog.
        </p>

        <div class="flex flex-wrap items-center gap-3 mb-6">
          <a
            href={calculatorUrl}
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold transition"
            style="background-color: var(--color-primary); color: #ffffff;"
          >
            Open Calculator
            <span aria-hidden="true">→</span>
          </a>
          <span class="text-sm text-text-muted">No signup · 100% free · Mobile-friendly</span>
        </div>

        <!-- Feature pills -->
        <div class="flex flex-wrap gap-2 text-xs">
          <span class="px-2.5 py-1 rounded-full bg-surface-elevated text-text-secondary border border-border">
            ARR · LTV · Payback
          </span>
          <span class="px-2.5 py-1 rounded-full bg-surface-elevated text-text-secondary border border-border">
            Industry benchmarks
          </span>
          <span class="px-2.5 py-1 rounded-full bg-surface-elevated text-text-secondary border border-border">
            CSV &amp; PDF export
          </span>
          <span class="px-2.5 py-1 rounded-full bg-surface-elevated text-text-secondary border border-border">
            Embeddable on your blog
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
