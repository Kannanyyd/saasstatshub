---
import type { BrowseCategoriesSection } from '../../lib/site-config';
import type { Category } from '../../lib/wp-api';
import { metaFor } from '../../lib/constants';
import Icon from '../Icon.astro';

interface Props {
  section: BrowseCategoriesSection;
  categories: Category[];
}

const { section, categories } = Astro.props;

// Filter & order by editor's visibleSlugs (if set)
let visible = categories;
if (section.visibleSlugs && section.visibleSlugs.length > 0) {
  const order = new Map(section.visibleSlugs.map((s, i) => [s, i]));
  visible = categories
    .filter((c) => order.has(c.slug))
    .sort((a, b) => (order.get(a.slug)! - order.get(b.slug)!));
}
---

<section class="mt-14 md:mt-16 bg-bg-alt border-y border-border">
  <div class="max-w-[1200px] mx-auto px-6 py-14 md:py-16">
    <div class="text-center mb-10">
      <div class="flex items-center justify-center gap-2 mb-2">
        <div class="w-8 h-1 rounded-full" style="background: linear-gradient(90deg, #7C3AED, #10B981);"></div>
        <span class="text-xs font-bold uppercase tracking-widest text-violet">{section.eyebrow || 'Explore'}</span>
        <div class="w-8 h-1 rounded-full" style="background: linear-gradient(90deg, #10B981, #7C3AED);"></div>
      </div>
      <h2 class="font-section-heading text-2xl md:text-3xl font-extrabold">{section.heading || 'Browse by Category'}</h2>
      {section.subheading && <p class="text-text-secondary mt-2">{section.subheading}</p>}
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5 stagger-children">
      {visible.map((cat) => {
        const meta = metaFor(cat.name, cat.slug);
        return (
          <a href={`/categories/${cat.slug}/`} class="category-card group animate-fade-in-up" style={`--card-color: ${meta.color}; --card-color-end: ${meta.colorEnd};`}>
            <div class="cat-icon" style={`background: ${meta.bg}; color: ${meta.color};`}>
              <Icon name={meta.iconName} aria-hidden="true" class="w-6 h-6" />
            </div>
            <h3 class="font-bold text-base text-text group-hover:text-primary transition-colors mb-1">{cat.name}</h3>
            <p class="text-xs text-text-muted">{meta.desc || `${cat.count} articles`}</p>
            <div class="mt-3 flex items-center gap-1 text-xs font-semibold text-primary opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all">
              Explore
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
