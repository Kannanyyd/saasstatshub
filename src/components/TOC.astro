---
interface Props {
  items: { id: string; text: string }[];
}

const { items } = Astro.props;
---

<details class="toc-mobile md:hidden">
  <summary>📋 Table of Contents</summary>
  <div class="toc-list">
    {items.map((item) => (
      <a href={`#${item.id}`}>{item.text}</a>
    ))}
  </div>
</details>

<nav class="toc hidden md:block" aria-label="Table of contents">
  <h3 class="text-sm font-bold mb-3">📋 Table of Contents</h3>
  {items.map((item) => (
    <a href={`#${item.id}`}>{item.text}</a>
  ))}
</nav>
