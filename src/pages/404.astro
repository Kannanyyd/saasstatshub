---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="max-w-[740px] mx-auto px-6 py-20 text-center">
    <div class="text-6xl font-bold text-primary mb-4">404</div>
    <h1 class="text-2xl font-bold mb-4">Page Not Found</h1>
    <p class="text-text-secondary mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a href="/" class="inline-block px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark transition-colors">
      ← Back to Home
    </a>
  </div>
</BaseLayout>
