<script is:inline>
  // ===== SaaS Pricing Calculator — vanilla JS, runs entirely client-side =====
  (function () {
    const $ = (id) => document.getElementById(id);

    // Default values match the form's HTML defaults — keep in sync.
    const DEFAULTS = {
      mrr: 50000,
      customers: 500,
      churn: 3,
      cac: 800,
      growth: 8,
    };

    // Day 2: Benchmark config — loaded from <script type="application/json"> injected by Astro
    let BENCHMARKS = [];
    const benchScript = document.getElementById('benchmarks-data');
    if (benchScript) {
      try {
        BENCHMARKS = JSON.parse(benchScript.textContent || '[]');
      } catch (e) {
        console.error('[calculator] failed to parse benchmarks JSON', e);
      }
    }
    // Build a quick id-keyed lookup
    const BENCHMARK_BY_ID = {};
    for (const b of BENCHMARKS) BENCHMARK_BY_ID[b.id] = b;

    /**
     * Find the matching tier for a value, given a benchmark config.
     *
     * Tiers are ordered ascending by threshold:
     *   higher-better → first tier whose `max` >= value wins (lower thresholds = worse tier)
     *   lower-better  → first tier whose `max` >= value wins (lower thresholds = better tier)
     *
     * The semantics differ but the lookup loop is identical because the tiers list
     * is already pre-ordered correctly per direction.
     */
    function classifyBenchmark(benchmarkId, rawValue) {
      const b = BENCHMARK_BY_ID[benchmarkId];
      if (!b) return null;
      if (!isFinite(rawValue) || rawValue < 0) return null;
      for (const tier of b.tiers) {
        if (rawValue <= tier.max) return tier;
      }
      // Fallback: last tier (Infinity bucket should always catch, but guard anyway)
      return b.tiers[b.tiers.length - 1];
    }

    /**
     * Update one benchmark row's value display + tier label/color.
     */
    function renderBenchmark(benchmarkId, rawValue, displayValue) {
      const row = document.querySelector(`[data-bench-id="${benchmarkId}"]`);
      if (!row) return;
      const valueEl = row.querySelector('[data-bench-value]');
      const tierEl = row.querySelector('[data-bench-tier]');
      if (!valueEl || !tierEl) return;

      valueEl.textContent = displayValue;

      const tier = classifyBenchmark(benchmarkId, rawValue);
      if (!tier) {
        tierEl.textContent = '—';
        tierEl.setAttribute('data-bench-tier', 'gray');
      } else {
        tierEl.textContent = tier.label;
        tierEl.setAttribute('data-bench-tier', tier.color);
      }
    }

    function readInputs() {
      return {
        mrr: parseFloat($('input-mrr').value) || 0,
        customers: parseFloat($('input-customers').value) || 0,
        churn: parseFloat($('input-churn').value) || 0,
        cac: parseFloat($('input-cac').value) || 0,
        growth: parseFloat($('input-growth').value) || 0,
      };
    }

    /**
     * Format USD with smart compaction:
     *  $1,234       → "$1,234"
     *  $12,345      → "$12.3K"
     *  $1,234,567   → "$1.23M"
     *  $1,234,567,890 → "$1.23B"
     */
    function formatUSD(n) {
      if (!isFinite(n) || isNaN(n)) return '—';
      const abs = Math.abs(n);
      const sign = n < 0 ? '-' : '';
      if (abs >= 1e9) return `${sign}$${(abs / 1e9).toFixed(2)}B`;
      if (abs >= 1e6) return `${sign}$${(abs / 1e6).toFixed(2)}M`;
      if (abs >= 1e4) return `${sign}$${(abs / 1e3).toFixed(1)}K`;
      // Below $10K, show full number with commas
      return `${sign}$${Math.round(abs).toLocaleString('en-US')}`;
    }

    function formatMonths(n) {
      if (!isFinite(n) || isNaN(n)) return '—';
      if (n >= 999) return '999+ mo';
      if (n < 1) return '<1 mo';
      return `${n.toFixed(1)} mo`;
    }

    function formatRatio(n) {
      if (!isFinite(n) || isNaN(n)) return '—';
      if (n >= 999) return '999+ : 1';
      return `${n.toFixed(1)} : 1`;
    }

    function formatPct(n) {
      if (!isFinite(n) || isNaN(n)) return '—';
      return `${n >= 0 ? '+' : ''}${n.toFixed(1)}%`;
    }

    /**
     * Tier classification matching operator's spec:
     * Display bands are illustrative UI guidance, not industry percentiles.
     */
    function tierForLtvCac(ratio) {
      if (!isFinite(ratio) || ratio <= 0) return 'bad';
      if (ratio < 1) return 'bad';
      if (ratio < 3) return 'warn';
      return 'good';
    }

    function tierLabelLtvCac(ratio) {
      if (!isFinite(ratio) || ratio <= 0) return 'Insufficient data';
      if (ratio < 1) return 'Unprofitable — CAC > LTV';
      if (ratio < 3) return 'Illustrative range: 1:1 to 3:1';
      if (ratio < 5) return 'Illustrative range: 3:1 to 5:1';
      return 'Illustrative range: above 5:1';
    }

    /**
     * Payback bands are illustrative UI guidance, not market benchmarks.
     */
    function tierForPayback(months) {
      if (!isFinite(months) || months <= 0) return 'bad';
      if (months <= 12) return 'good';
      if (months <= 24) return 'warn';
      return 'bad';
    }

    function tierLabelPayback(months) {
      if (!isFinite(months) || months <= 0) return '—';
      if (months <= 12) return 'Illustrative range: 12 months or less';
      if (months <= 24) return 'Illustrative range: 12-24 months';
      return 'Illustrative range: above 24 months';
    }

    function compute(inputs) {
      const { mrr, customers, churn, cac, growth } = inputs;

      // ARPU = MRR / customers (avoid div-by-zero)
      const arpc = customers > 0 ? mrr / customers : 0;

      // Customer lifetime in months = 1 / monthly churn rate
      // Churn input is %; convert to decimal
      const lifetimeMonths = churn > 0 ? 100 / churn : Infinity;

      // LTV = ARPU × lifetime
      const ltv = arpc * lifetimeMonths;

      // LTV:CAC ratio
      const ltvCac = cac > 0 ? ltv / cac : Infinity;

      // CAC payback period in months = CAC / ARPU (gross margin assumed 100%; future enhancement: gross margin input)
      const payback = arpc > 0 ? cac / arpc : Infinity;

      // ARR
      const arr = mrr * 12;

      // MRR forecast — compound monthly: MRR_n = MRR_0 × (1 + g)^n
      const g = growth / 100;
      const mrr6 = mrr * Math.pow(1 + g, 6);
      const mrr12 = mrr * Math.pow(1 + g, 12);
      const mrr24 = mrr * Math.pow(1 + g, 24);

      // Annual growth (compounded)
      const annualGrowth = (Math.pow(1 + g, 12) - 1) * 100;

      return {
        arr, arpc, lifetimeMonths, ltv, ltvCac, payback, mrr6, mrr12, mrr24, annualGrowth,
      };
    }

    function render() {
      const inputs = readInputs();
      const r = compute(inputs);

      $('out-arr').textContent = formatUSD(r.arr);
      $('out-mrr-echo').textContent = inputs.mrr.toLocaleString('en-US');
      $('out-arpc').textContent = formatUSD(r.arpc);
      $('out-lifetime').textContent = formatMonths(r.lifetimeMonths);
      $('out-ltv').textContent = formatUSD(r.ltv);
      $('out-ltv-cac').textContent = formatRatio(r.ltvCac);
      $('out-ltv-cac-tier').textContent = tierLabelLtvCac(r.ltvCac);
      $('out-payback').textContent = formatMonths(r.payback);
      $('out-payback-tier').textContent = tierLabelPayback(r.payback);
      $('out-annual-growth').textContent = formatPct(r.annualGrowth);
      $('out-mrr-6mo').textContent = formatUSD(r.mrr6);
      $('out-mrr-12mo').textContent = formatUSD(r.mrr12);
      $('out-mrr-24mo').textContent = formatUSD(r.mrr24);

      // Tier coloring on LTV:CAC and payback
      $('out-ltv-cac').setAttribute('data-tier', tierForLtvCac(r.ltvCac));
      $('out-payback').setAttribute('data-tier', tierForPayback(r.payback));

      // ===== Day 2: Benchmark card rendering =====
      renderBenchmark('arr', r.arr, formatUSD(r.arr));
      renderBenchmark('ltvcac', r.ltvCac, formatRatio(r.ltvCac));
      renderBenchmark('churn', inputs.churn, `${inputs.churn.toFixed(1)}%`);
      renderBenchmark('payback', r.payback, formatMonths(r.payback));
      renderBenchmark('growth', r.annualGrowth, formatPct(r.annualGrowth));

      // ===== Day 2: Conditional CTA 1 — show when LTV:CAC < 3 =====
      const cta1 = $('cta-low-ltvcac');
      if (cta1) {
        const showCta = isFinite(r.ltvCac) && r.ltvCac < 3 && r.ltvCac > 0;
        cta1.classList.toggle('hidden', !showCta);
      }
    }

    function attachListeners() {
      // ===== Day 4: GA4 event tracking =====
      // - Funnel step 1: first input change (real-use vs view-only)
      // - Funnel completion: count distinct fields the user touched
      // - Conversion events: CSV/PDF download, embed copy
      // - CTA clicks: internal CTAs and source links
      // - UX signal: Reset button (frustration indicator)
      const touchedFields = new Set();
      let firstInputFired = false;

      const ids = ['input-mrr', 'input-customers', 'input-churn', 'input-cac', 'input-growth'];
      ids.forEach((id) => {
        const el = $(id);
        if (!el) return;
        el.addEventListener('input', () => {
          render();
          if (!firstInputFired) {
            firstInputFired = true;
            track('calc_input_changed');  // Funnel step 1: real engagement
          }
          if (!touchedFields.has(id)) {
            touchedFields.add(id);
            track('calc_input_count', { count: touchedFields.size, field: id });
          }
        });
      });

      const reset = $('btn-reset');
      if (reset) {
        reset.addEventListener('click', () => {
          $('input-mrr').value = DEFAULTS.mrr;
          $('input-customers').value = DEFAULTS.customers;
          $('input-churn').value = DEFAULTS.churn;
          $('input-cac').value = DEFAULTS.cac;
          $('input-growth').value = DEFAULTS.growth;
          render();
          track('calc_reset');
        });
      }

      // Day 2: CSV export (track happens inside exportCSV)
      const csvBtn = $('btn-export-csv');
      if (csvBtn) {
        csvBtn.addEventListener('click', exportCSV);
      }

      // Day 4: track all CTA + source link clicks via delegation
      attachCtaTracking();
    }

    /**
     * GA4 event tracking helper. Safe no-op if gtag not loaded
     * (e.g. user denied analytics consent).
     */
    function track(eventName, params) {
      try {
        if (typeof window.gtag === 'function') {
          window.gtag('event', eventName, Object.assign({
            event_category: 'calculator',
            page_path: '/saas-pricing-calculator/',
          }, params || {}));
        }
      } catch (e) {
        // Don't let tracking errors break the user flow
      }
    }

    /**
     * Attach click trackers to all CTA buttons + benchmark source links.
     * Uses event delegation on the article so dynamically-shown CTAs
     * (like CTA 1 conditional) are also covered.
     */
    function attachCtaTracking() {
      // Bottom resource CTAs
      document.querySelectorAll('a[data-internal-cta]').forEach((a) => {
        a.addEventListener('click', () => {
          track('calc_cta_internal', { target: a.getAttribute('data-internal-cta') });
        });
      });

      // CTA 1 (conditional, LTV:CAC < 3) — link to /crm/salesforce-vs-hubspot-vs-pipedrive/
      const cta1Link = document.querySelector('#cta-low-ltvcac a[href*="/crm/"]');
      if (cta1Link) {
        cta1Link.addEventListener('click', () => track('calc_cta_crm_compare'));
      }

      // CTA 2 (static) — "See Best CRM Software"
      document.querySelectorAll('a[href="/crm/best-crm-small-business/"]:not([data-internal-cta])').forEach((a) => {
        a.addEventListener('click', () => track('calc_cta_best_crm'));
      });

      // CTA 4 (top banner) — State of SaaS report
      document.querySelectorAll('a[href="/analytics/state-of-saas-2026-annual-report/"]').forEach((a) => {
        a.addEventListener('click', () => track('calc_cta_state_of_saas'));
      });

      // Benchmark source links — internal articles linked from each row
      document.querySelectorAll('.benchmark-row a[href^="/"]').forEach((a) => {
        const sourceUrl = a.getAttribute('href');
        a.addEventListener('click', () => track('calc_source_click', { destination: sourceUrl }));
      });
    }

    /**
     * Build a CSV with two sections:
     *  1. Inputs (what the user typed)
     *  2. Results (all computed metrics + benchmark tier per indicator)
     * Then trigger a download via Blob URL.
     */
    function exportCSV() {
      const inputs = readInputs();
      const r = compute(inputs);
      const ts = new Date().toISOString().slice(0, 10);

      const rows = [];
      rows.push(['SaaSStatsHub — SaaS Pricing Calculator Export']);
      rows.push([`Generated: ${ts}`]);
      rows.push([`URL: https://saasstatshub.com/saas-pricing-calculator/`]);
      rows.push([]);

      rows.push(['INPUTS', '', '']);
      rows.push(['Metric', 'Value', 'Unit']);
      rows.push(['Monthly Recurring Revenue (MRR)', inputs.mrr, 'USD']);
      rows.push(['Active customers', inputs.customers, 'count']);
      rows.push(['Monthly churn rate', inputs.churn, '%']);
      rows.push(['Customer Acquisition Cost (CAC)', inputs.cac, 'USD']);
      rows.push(['Monthly MRR growth rate', inputs.growth, '%']);
      rows.push([]);

      rows.push(['RESULTS', '', '']);
      rows.push(['Metric', 'Value', 'Unit']);
      rows.push(['Annual Recurring Revenue (ARR)', Math.round(r.arr), 'USD']);
      rows.push(['Avg Revenue per Customer (ARPU)', Math.round(r.arpc * 100) / 100, 'USD/month']);
      rows.push(['Customer lifetime', isFinite(r.lifetimeMonths) ? Math.round(r.lifetimeMonths * 10) / 10 : 'Infinite', 'months']);
      rows.push(['Lifetime Value (LTV)', isFinite(r.ltv) ? Math.round(r.ltv) : 'Infinite', 'USD']);
      rows.push(['LTV : CAC ratio', isFinite(r.ltvCac) ? Math.round(r.ltvCac * 10) / 10 : 'Infinite', 'ratio']);
      rows.push(['CAC Payback Period', isFinite(r.payback) ? Math.round(r.payback * 10) / 10 : 'Infinite', 'months']);
      rows.push(['Annual growth rate', Math.round(r.annualGrowth * 10) / 10, '%']);
      rows.push(['MRR forecast — 6 months', Math.round(r.mrr6), 'USD']);
      rows.push(['MRR forecast — 12 months', Math.round(r.mrr12), 'USD']);
      rows.push(['MRR forecast — 24 months', Math.round(r.mrr24), 'USD']);
      rows.push([]);

      rows.push(['BENCHMARK COMPARISON', '', '']);
      rows.push(['Indicator', 'Your value', 'Tier vs SaaS industry']);
      const benchValues = {
        arr: { val: Math.round(r.arr), display: formatUSD(r.arr) },
        ltvcac: { val: r.ltvCac, display: formatRatio(r.ltvCac) },
        churn: { val: inputs.churn, display: `${inputs.churn.toFixed(1)}%` },
        payback: { val: r.payback, display: formatMonths(r.payback) },
        growth: { val: r.annualGrowth, display: formatPct(r.annualGrowth) },
      };
      for (const b of BENCHMARKS) {
        const v = benchValues[b.id];
        if (!v) continue;
        const tier = classifyBenchmark(b.id, v.val);
        rows.push([b.label, v.display, tier ? tier.label : '—']);
      }
      rows.push([]);
      rows.push(['Note: Planning ranges are illustrative and are not audited industry benchmarks.']);

      // Encode CSV — quote any field containing comma/quote/newline
      const csv = rows
        .map((row) =>
          row
            .map((cell) => {
              const s = String(cell ?? '');
              if (/[,"\n\r]/.test(s)) return `"${s.replace(/"/g, '""')}"`;
              return s;
            })
            .join(',')
        )
        .join('\r\n');

      // BOM for Excel UTF-8 compatibility
      const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `saas-pricing-calculator-${ts}.csv`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      // Free the blob URL after a tick
      setTimeout(() => URL.revokeObjectURL(url), 1000);

      track('calc_csv_download');
    }

    // ===== Day 3: Embed mode + PDF download + Embed copy =====

    /**
     * Detect embed mode via ?embed=1 URL parameter.
     * When true, body gets class .embed-mode → CSS hides nav/footer/CTAs/breadcrumb.
     */
    function applyEmbedMode() {
      try {
        const params = new URLSearchParams(window.location.search);
        if (params.get('embed') === '1') {
          document.documentElement.classList.add('embed-mode');
        }
      } catch (e) {
        // No-op — older browsers or sandboxed iframe
      }
    }

    /**
     * Copy embed iframe code to clipboard.
     * Falls back to execCommand for older browsers.
     */
    function attachEmbedCopy() {
      const btn = $('btn-copy-embed');
      const textarea = $('embed-code');
      const status = $('embed-status');
      if (!btn || !textarea) return;

      btn.addEventListener('click', async () => {
        const code = textarea.value;
        try {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            await navigator.clipboard.writeText(code);
          } else {
            // Fallback: select + execCommand
            textarea.select();
            document.execCommand('copy');
          }
          btn.textContent = 'Copied!';
          if (status) status.textContent = 'Embed code copied to clipboard.';
          setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
          track('calc_embed_copy');
        } catch (e) {
          if (status) status.textContent = 'Copy failed — please select and copy manually.';
        }
      });

      // Click textarea → select all (UX: easy manual copy)
      textarea.addEventListener('focus', () => textarea.select());
    }

    /**
     * Generate a 1-page PDF report client-side using jsPDF (loaded on demand from CDN).
     * Layout: header (logo/title) → inputs → results → benchmark table → footer (URL/disclaimer)
     */
    function attachPdfDownload() {
      const btn = $('btn-download-pdf');
      const status = $('pdf-status');
      if (!btn) return;

      btn.addEventListener('click', async () => {
        if (status) status.textContent = 'Generating PDF...';
        btn.disabled = true;

        try {
          // Lazy-load jsPDF from CDN — keeps initial page fast
          const jsPDF = await loadJsPDF();
          const pdf = new jsPDF({ unit: 'pt', format: 'a4' }); // 595 x 842 pt
          buildPdf(pdf);
          const ts = new Date().toISOString().slice(0, 10);
          pdf.save(`saas-pricing-calculator-report-${ts}.pdf`);
          if (status) status.textContent = 'PDF downloaded.';
          track('calc_pdf_download');
        } catch (e) {
          console.error('[calculator] PDF generation failed', e);
          if (status) status.textContent = 'PDF generation failed. Try CSV export instead.';
        } finally {
          btn.disabled = false;
          setTimeout(() => { if (status) status.textContent = ''; }, 4000);
        }
      });
    }

    /**
     * Lazy-load jsPDF from cdnjs. Cached on window after first load.
     */
    function loadJsPDF() {
      if (window.jspdf && window.jspdf.jsPDF) return Promise.resolve(window.jspdf.jsPDF);
      return new Promise((resolve, reject) => {
        const s = document.createElement('script');
        s.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
        s.onload = () => {
          if (window.jspdf && window.jspdf.jsPDF) resolve(window.jspdf.jsPDF);
          else reject(new Error('jsPDF not on window'));
        };
        s.onerror = () => reject(new Error('Failed to load jsPDF'));
        document.head.appendChild(s);
      });
    }

    /**
     * Render the actual PDF content. Uses jsPDF's basic text/rect/line APIs
     * (no html2canvas to keep deps small and avoid font/style mismatch).
     */
    function buildPdf(pdf) {
      const inputs = readInputs();
      const r = compute(inputs);

      const PAGE_W = 595;
      const PAGE_H = 842;
      const MARGIN = 40;
      const ts = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

      // ===== Header =====
      pdf.setFillColor(15, 26, 46); // #0F1A2E
      pdf.rect(0, 0, PAGE_W, 80, 'F');
      pdf.setTextColor(255, 255, 255);
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(22);
      pdf.text('SaaS Pricing & Metrics Report', MARGIN, 35);
      pdf.setFont('helvetica', 'normal');
      pdf.setFontSize(10);
      pdf.setTextColor(148, 163, 184); // #94A3B8
      pdf.text(`Generated ${ts} · saasstatshub.com/saas-pricing-calculator`, MARGIN, 55);

      let y = 110;

      // ===== Inputs section =====
      pdf.setTextColor(15, 23, 42);
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(12);
      pdf.text('YOUR INPUTS', MARGIN, y);
      y += 18;

      pdf.setFont('helvetica', 'normal');
      pdf.setFontSize(10);
      pdf.setTextColor(60, 71, 89);

      const inputRows = [
        ['Monthly Recurring Revenue', `$${inputs.mrr.toLocaleString()}`],
        ['Active customers', inputs.customers.toLocaleString()],
        ['Monthly churn rate', `${inputs.churn.toFixed(1)}%`],
        ['Customer Acquisition Cost', `$${inputs.cac.toLocaleString()}`],
        ['Monthly MRR growth rate', `${inputs.growth.toFixed(1)}%`],
      ];
      inputRows.forEach((row) => {
        pdf.text(row[0], MARGIN, y);
        pdf.setFont('helvetica', 'bold');
        pdf.text(row[1], PAGE_W - MARGIN, y, { align: 'right' });
        pdf.setFont('helvetica', 'normal');
        y += 16;
      });

      y += 14;

      // ===== Results section =====
      pdf.setFillColor(241, 245, 249); // #F1F5F9
      pdf.rect(MARGIN, y - 14, PAGE_W - 2 * MARGIN, 1, 'F');

      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(12);
      pdf.setTextColor(15, 23, 42);
      pdf.text('YOUR RESULTS', MARGIN, y);
      y += 6;

      // ARR — big headline
      pdf.setFontSize(28);
      pdf.setTextColor(59, 130, 246);
      pdf.text(formatUSD(r.arr), MARGIN, y + 24);
      pdf.setFont('helvetica', 'normal');
      pdf.setFontSize(9);
      pdf.setTextColor(148, 163, 184);
      pdf.text('ANNUAL RECURRING REVENUE', MARGIN, y + 38);
      y += 60;

      // Other key metrics — 2 columns
      const metrics = [
        ['LTV', formatUSD(r.ltv)],
        ['LTV : CAC ratio', formatRatio(r.ltvCac)],
        ['Customer lifetime', formatMonths(r.lifetimeMonths)],
        ['CAC payback period', formatMonths(r.payback)],
        ['ARPU per month', formatUSD(r.arpc)],
        ['Annual growth rate', formatPct(r.annualGrowth)],
      ];
      pdf.setFontSize(10);
      const colW = (PAGE_W - 2 * MARGIN) / 2;
      metrics.forEach((m, i) => {
        const col = i % 2;
        const row = Math.floor(i / 2);
        const x = MARGIN + col * colW;
        const rowY = y + row * 22;
        pdf.setTextColor(60, 71, 89);
        pdf.setFont('helvetica', 'normal');
        pdf.text(m[0], x, rowY);
        pdf.setFont('helvetica', 'bold');
        pdf.setTextColor(15, 23, 42);
        pdf.text(m[1], x + colW - 10, rowY, { align: 'right' });
      });
      y += Math.ceil(metrics.length / 2) * 22 + 10;

      // MRR Forecast strip
      pdf.setFillColor(248, 250, 252); // #F8FAFC
      pdf.rect(MARGIN, y, PAGE_W - 2 * MARGIN, 50, 'F');
      pdf.setFontSize(9);
      pdf.setTextColor(148, 163, 184);
      pdf.text('MRR FORECAST', MARGIN + 12, y + 16);

      pdf.setFontSize(13);
      pdf.setFont('helvetica', 'bold');
      pdf.setTextColor(15, 23, 42);
      const fcWidth = (PAGE_W - 2 * MARGIN - 24) / 3;
      ['6 months', '12 months', '24 months'].forEach((label, i) => {
        const fcX = MARGIN + 12 + i * fcWidth;
        const val = i === 0 ? r.mrr6 : i === 1 ? r.mrr12 : r.mrr24;
        pdf.setFontSize(9);
        pdf.setFont('helvetica', 'normal');
        pdf.setTextColor(148, 163, 184);
        pdf.text(label, fcX, y + 32);
        pdf.setFont('helvetica', 'bold');
        pdf.setFontSize(13);
        pdf.setTextColor(15, 23, 42);
        pdf.text(formatUSD(val), fcX, y + 46);
      });
      y += 70;

      // ===== Benchmark comparison =====
      pdf.setFont('helvetica', 'bold');
      pdf.setFontSize(12);
      pdf.setTextColor(15, 23, 42);
      pdf.text('HOW YOU COMPARE', MARGIN, y);
      y += 6;
      pdf.setFont('helvetica', 'normal');
      pdf.setFontSize(8);
      pdf.setTextColor(148, 163, 184);
      pdf.text('Illustrative planning ranges; not audited industry benchmarks', MARGIN, y + 10);
      y += 28;

      // 5 benchmark rows
      const benchValues = {
        arr: { val: r.arr, display: formatUSD(r.arr) },
        ltvcac: { val: r.ltvCac, display: formatRatio(r.ltvCac) },
        churn: { val: inputs.churn, display: `${inputs.churn.toFixed(1)}%` },
        payback: { val: r.payback, display: formatMonths(r.payback) },
        growth: { val: r.annualGrowth, display: formatPct(r.annualGrowth) },
      };

      pdf.setFontSize(9);
      for (const b of BENCHMARKS) {
        const v = benchValues[b.id];
        if (!v) continue;
        const tier = classifyBenchmark(b.id, v.val);

        // Indicator label (left)
        pdf.setFont('helvetica', 'bold');
        pdf.setTextColor(60, 71, 89);
        pdf.text(b.label, MARGIN, y);

        // Your value (middle)
        pdf.setTextColor(15, 23, 42);
        pdf.text(v.display, MARGIN + 100, y);

        // Tier label (right) — colored
        if (tier) {
          if (tier.color === 'green') pdf.setTextColor(16, 185, 129);
          else if (tier.color === 'yellow') pdf.setTextColor(202, 138, 4);
          else if (tier.color === 'red') pdf.setTextColor(220, 38, 38);
          else pdf.setTextColor(100, 116, 139);
          pdf.setFont('helvetica', 'normal');
          pdf.setFontSize(8);
          pdf.text(tier.label, PAGE_W - MARGIN, y, { align: 'right' });
          pdf.setFontSize(9);
        }
        y += 16;
      }

      // ===== Footer =====
      const footerY = PAGE_H - 60;
      pdf.setDrawColor(226, 232, 240);
      pdf.line(MARGIN, footerY - 16, PAGE_W - MARGIN, footerY - 16);

      pdf.setFontSize(8);
      pdf.setFont('helvetica', 'normal');
      pdf.setTextColor(148, 163, 184);
      pdf.text('Generated by SaaSStatsHub Pricing Calculator', MARGIN, footerY);
      pdf.text('saasstatshub.com/saas-pricing-calculator', PAGE_W - MARGIN, footerY, { align: 'right' });

      pdf.setFontSize(7);
      pdf.text(
        'Calculations are based on the inputs you provide. Results are for educational purposes — consult a financial advisor for material business decisions.',
        MARGIN,
        footerY + 14,
        { maxWidth: PAGE_W - 2 * MARGIN }
      );
    }

    // Initial render with defaults
    document.addEventListener('DOMContentLoaded', () => {
      applyEmbedMode();
      attachListeners();
      attachEmbedCopy();
      attachPdfDownload();
      render();
    });
  })();
</script>
