---
/**
 * SaaS Pricing Calculator — Day 2
 *
 * Day 1 (shipped): 5 inputs + 10 calculated metrics + tier coloring
 * Day 2 (this commit):
 *   - Top info banner → CTA 4 (State of SaaS report)
 *   - "How You Compare" benchmark card → 5 indicators with live tier classification
 *     vs SaaSStatsHub data, source link to original article
 *   - Conditional CTA 1 (CRM comparison) — shows when LTV:CAC < 3
 *   - Static CTA 2 (Best CRM software) — always at bottom of benchmark card
 *   - Bottom banner CTA 3 (internal CRM comparison + best CRM guide)
 *   - CSV export button
 *
 * Day 3 (next): embed code generator + 1-page PDF report
 *
 * 路径：https://saasstatshub.com/saas-pricing-calculator/
 * 目标关键词：SaaS pricing calculator / LTV CAC calculator / SaaS metrics calculator
 *
 * Benchmark data source: D:\Agent\WEB\WEB1\SEO\plans\benchmarks-pricing-calculator.md (operations team, v1.0)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const title = 'SaaS Metrics and Spend Calculator: LTV, CAC, MRR and ARR';
const description =
  'Free SaaS metrics calculator for ARR, MRR, LTV, CAC ratio, payback period, and revenue forecasts using your pricing, customer, churn, and cost assumptions.';

/**
 * Benchmark configuration — values from operations team, sourced from main-site articles.
 * The runtime JS classifies the user's calculated values against these tiers and renders
 * the matching label/color + benchmark text + source article link.
 *
 * Tier-direction note:
 *   - Most metrics: higher = better (ARR, LTV:CAC, growth)
 *   - Inverse metrics: lower = better (churn, payback). The `direction` field flips
 *     the logic so we can use a single classifier function.
 */
const BENCHMARKS = [
  {
    id: 'arr',
    label: 'ARR',
    direction: 'higher-better',
    tiers: [
      { max: 1_000_000, label: 'Illustrative band: under $1M ARR', color: 'yellow' },
      { max: 10_000_000, label: 'Illustrative band: $1M-$10M ARR', color: 'green' },
      { max: 50_000_000, label: 'Illustrative band: $10M-$50M ARR', color: 'green' },
      { max: Infinity, label: 'Illustrative band: above $50M ARR', color: 'green' },
    ],
    text: 'ARR is shown in broad scale bands for planning convenience. Funding stage cannot be inferred from ARR alone, and these bands are not market benchmarks.',
    sourceLabel: 'SaaS Industry Statistics 2026',
    sourceUrl: '/analytics/saas-industry-statistics-2026/',
  },
  {
    id: 'ltvcac',
    label: 'LTV : CAC',
    direction: 'higher-better',
    tiers: [
      { max: 1, label: 'Illustrative band: below 1:1', color: 'red' },
      { max: 3, label: 'Illustrative band: 1:1 to 3:1', color: 'yellow' },
      { max: 5, label: 'Illustrative band: 3:1 to 5:1', color: 'green' },
      { max: Infinity, label: 'Illustrative band: above 5:1', color: 'green' },
    ],
    text: 'LTV:CAC is a planning ratio, not a universal score. Interpret it alongside gross margin, cash timing, retention, and the assumptions used to estimate lifetime value.',
    sourceLabel: 'SaaS Pricing Statistics 2026',
    sourceUrl: '/marketing/saas-pricing-statistics-2026/',
  },
  {
    id: 'churn',
    label: 'Monthly Churn',
    direction: 'lower-better',
    tiers: [
      { max: 1, label: 'Illustrative band: under 1% monthly', color: 'green' },
      { max: 2, label: 'Illustrative band: 1%-2% monthly', color: 'green' },
      { max: 5, label: 'Illustrative band: 2%-5% monthly', color: 'yellow' },
      { max: Infinity, label: 'Illustrative band: above 5% monthly', color: 'red' },
    ],
    text: 'Monthly churn is grouped into illustrative ranges. The appropriate range depends on customer segment, contract length, calculation method, and business maturity.',
    sourceLabel: 'SaaS Churn Rate Statistics 2026',
    sourceUrl: '/analytics/saas-churn-rate-statistics-2026/',
  },
  {
    id: 'payback',
    label: 'CAC Payback',
    direction: 'lower-better',
    tiers: [
      { max: 12, label: 'Illustrative band: 12 months or less', color: 'green' },
      { max: 24, label: 'Illustrative band: 12-24 months', color: 'yellow' },
      { max: Infinity, label: 'Illustrative band: above 24 months', color: 'red' },
    ],
    text: 'Payback is grouped into planning ranges only. A sustainable period depends on gross margin, available cash, contract terms, retention, and the cost of capital.',
    sourceLabel: 'SaaS Pricing Statistics 2026',
    sourceUrl: '/marketing/saas-pricing-statistics-2026/',
  },
  {
    id: 'growth',
    label: 'Annual Growth',
    direction: 'higher-better',
    tiers: [
      { max: 20, label: 'Illustrative band: under 20% annualized', color: 'red' },
      { max: 40, label: 'Illustrative band: 20%-40% annualized', color: 'yellow' },
      { max: 100, label: 'Illustrative band: 40%-100% annualized', color: 'green' },
      { max: Infinity, label: 'Illustrative band: above 100% annualized', color: 'green' },
    ],
    text: 'Growth is grouped into illustrative annualized ranges. Compare the result with your own plan and prior periods rather than treating it as an industry percentile.',
    sourceLabel: 'State of SaaS 2026',
    sourceUrl: '/analytics/state-of-saas-2026-annual-report/',
  },
];

// Schema.org WebApplication marker — helps Google understand this is a tool, not an article
const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'SaaS Pricing Calculator',
  url: 'https://saasstatshub.com/saas-pricing-calculator/',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description,
  publisher: {
    '@type': 'Organization',
    name: 'SaaSStatsHub',
    url: 'https://saasstatshub.com',
  },
};
---

<BaseLayout title={title} description={description}>
  <!-- Schema.org WebApplication marker (legal in body per Google guidelines) -->
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />

  <!-- Benchmarks config (serialized JSON, parsed by client JS) -->
  <script type="application/json" id="benchmarks-data" set:html={JSON.stringify(BENCHMARKS)} />

  <article class="max-w-[1100px] mx-auto px-6 py-10 md:py-14">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="text-xs text-text-muted mb-6 font-mono uppercase tracking-wide">
      <a href="/" class="hover:text-text-secondary">Home</a>
      <span class="mx-2">/</span>
      <span class="text-text-secondary">SaaS Pricing Calculator</span>
    </nav>

    <!-- CTA 4 — Top info banner: pointer to State of SaaS 2026 for users who need reference data -->
    <div class="embed-hide mb-8 flex items-start md:items-center gap-3 px-4 py-3 rounded-lg bg-primary-lighter border border-primary-deeper text-sm">
      <span class="text-base shrink-0" aria-hidden="true">💡</span>
      <p class="text-text-secondary">
        Need data to estimate?
        <a href="/analytics/state-of-saas-2026-annual-report/" class="text-primary hover:underline font-semibold">
          See our State of SaaS 2026 report
        </a>
        for source-scoped industry context →
      </p>
    </div>

    <!-- Embed-mode minimal header (only visible inside iframes) -->
    <div class="embed-only mb-6 pb-3 border-b border-border">
      <p class="text-xl font-bold text-text">SaaS Pricing &amp; Metrics Calculator</p>
      <p class="text-xs text-text-muted mt-1">Calculate ARR, LTV, payback &amp; more — free</p>
    </div>

    <!-- Hero -->
    <header class="embed-hide mb-10 text-center max-w-3xl mx-auto">
      <p class="text-xs text-text-muted uppercase tracking-widest font-mono mb-3">
        Free Tool
      </p>
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4 leading-tight">
        SaaS Pricing &amp;<br class="md:hidden" />
        <span class="gradient-text-primary">Metrics Calculator</span>
      </h1>
      <p class="text-base md:text-lg text-text-secondary leading-relaxed">
        Calculate your ARR, LTV, LTV:CAC ratio, payback period, and 12-24 month forecast.
        Review your results against clearly labeled illustrative planning ranges.
      </p>
    </header>

    <!-- Calculator Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-[420px_1fr] gap-8 mb-12">
      <!-- ===== Input Form ===== -->
      <section class="card-input bg-surface border border-border rounded-xl p-6 md:p-8">
        <h2 class="text-lg font-bold text-text mb-1">Your numbers</h2>
        <p class="text-xs text-text-muted mb-6 font-mono">
          Calculations update as you type
        </p>

        <div class="space-y-5">
          <!-- MRR -->
          <div>
            <label for="input-mrr" class="block text-sm font-semibold text-text mb-1.5">
              Monthly Recurring Revenue (MRR)
              <span class="text-text-muted font-normal">— current</span>
            </label>
            <div class="relative">
              <span class="prefix-symbol">$</span>
              <input
                type="number"
                id="input-mrr"
                inputmode="numeric"
                min="0"
                step="100"
                value="50000"
                class="calc-input has-prefix"
                aria-describedby="hint-mrr"
              />
            </div>
            <p id="hint-mrr" class="text-xs text-text-muted mt-1">Total revenue you bill every month</p>
          </div>

          <!-- Customers -->
          <div>
            <label for="input-customers" class="block text-sm font-semibold text-text mb-1.5">
              Active customers
            </label>
            <input
              type="number"
              id="input-customers"
              inputmode="numeric"
              min="1"
              step="1"
              value="500"
              class="calc-input"
              aria-describedby="hint-customers"
            />
            <p id="hint-customers" class="text-xs text-text-muted mt-1">Paying customers right now</p>
          </div>

          <!-- Churn Rate -->
          <div>
            <label for="input-churn" class="block text-sm font-semibold text-text mb-1.5">
              Monthly churn rate
            </label>
            <div class="relative">
              <input
                type="number"
                id="input-churn"
                inputmode="decimal"
                min="0"
                max="100"
                step="0.1"
                value="3"
                class="calc-input has-suffix"
                aria-describedby="hint-churn"
              />
              <span class="suffix-symbol">%</span>
            </div>
            <p id="hint-churn" class="text-xs text-text-muted mt-1">% of customers who cancel each month</p>
          </div>

          <!-- CAC -->
          <div>
            <label for="input-cac" class="block text-sm font-semibold text-text mb-1.5">
              Customer Acquisition Cost (CAC)
            </label>
            <div class="relative">
              <span class="prefix-symbol">$</span>
              <input
                type="number"
                id="input-cac"
                inputmode="numeric"
                min="0"
                step="10"
                value="800"
                class="calc-input has-prefix"
                aria-describedby="hint-cac"
              />
            </div>
            <p id="hint-cac" class="text-xs text-text-muted mt-1">Total marketing &amp; sales spend ÷ new customers</p>
          </div>

          <!-- Growth Rate -->
          <div>
            <label for="input-growth" class="block text-sm font-semibold text-text mb-1.5">
              Monthly MRR growth rate
            </label>
            <div class="relative">
              <input
                type="number"
                id="input-growth"
                inputmode="decimal"
                min="-50"
                max="100"
                step="0.5"
                value="8"
                class="calc-input has-suffix"
                aria-describedby="hint-growth"
              />
              <span class="suffix-symbol">%</span>
            </div>
            <p id="hint-growth" class="text-xs text-text-muted mt-1">Net new MRR added each month, %</p>
          </div>
        </div>

        <button
          type="button"
          id="btn-reset"
          class="mt-6 w-full text-sm py-2 rounded border border-border text-text-secondary hover:border-primary hover:text-text transition"
        >
          Reset to defaults
        </button>
      </section>

      <!-- ===== Results ===== -->
      <section class="space-y-4">
        <!-- Headline ARR -->
        <div class="bg-surface border border-border rounded-xl p-6 md:p-8 relative overflow-hidden">
          <p class="text-xs text-text-muted uppercase tracking-widest font-mono mb-2">
            Annual Recurring Revenue
          </p>
          <p class="text-4xl md:text-5xl font-extrabold text-text font-mono mb-1" id="out-arr">
            $0
          </p>
          <p class="text-sm text-text-muted">
            Based on $<span id="out-mrr-echo">0</span> MRR × 12
          </p>
        </div>

        <!-- 4 metric tiles -->
        <div class="grid grid-cols-2 gap-3 md:gap-4">
          <div class="metric-tile">
            <div class="metric-label">Avg revenue per customer</div>
            <div class="metric-value" id="out-arpc">$0</div>
            <div class="metric-foot">ARPU per month</div>
          </div>
          <div class="metric-tile">
            <div class="metric-label">Customer lifetime</div>
            <div class="metric-value" id="out-lifetime">0 mo</div>
            <div class="metric-foot">1 / churn rate</div>
          </div>
          <div class="metric-tile">
            <div class="metric-label">Lifetime Value (LTV)</div>
            <div class="metric-value" id="out-ltv">$0</div>
            <div class="metric-foot">ARPU × lifetime</div>
          </div>
          <div class="metric-tile">
            <div class="metric-label">LTV : CAC ratio</div>
            <div class="metric-value" id="out-ltv-cac">0:1</div>
            <div class="metric-foot" id="out-ltv-cac-tier">—</div>
          </div>
        </div>

        <!-- Payback + Forecast -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="metric-tile">
            <div class="metric-label">CAC Payback Period</div>
            <div class="metric-value" id="out-payback">0 months</div>
            <div class="metric-foot" id="out-payback-tier">—</div>
          </div>
          <div class="metric-tile">
            <div class="metric-label">Annual growth rate</div>
            <div class="metric-value" id="out-annual-growth">0%</div>
            <div class="metric-foot">Compounded monthly</div>
          </div>
        </div>

        <!-- Forecast -->
        <div class="bg-surface border border-border rounded-xl p-6">
          <p class="text-xs text-text-muted uppercase tracking-widest font-mono mb-3">
            MRR Forecast
          </p>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div>
              <p class="text-xs text-text-muted mb-1">In 6 months</p>
              <p class="text-xl md:text-2xl font-bold font-mono text-text" id="out-mrr-6mo">$0</p>
            </div>
            <div class="border-x border-border">
              <p class="text-xs text-text-muted mb-1">In 12 months</p>
              <p class="text-xl md:text-2xl font-bold font-mono text-text" id="out-mrr-12mo">$0</p>
            </div>
            <div>
              <p class="text-xs text-text-muted mb-1">In 24 months</p>
              <p class="text-xl md:text-2xl font-bold font-mono text-text" id="out-mrr-24mo">$0</p>
            </div>
          </div>
          <p class="text-xs text-text-muted mt-3 text-center">
            Forecast assumes constant monthly growth rate &amp; churn. Real growth is rarely linear.
          </p>
        </div>

        <!-- Export CSV button -->
        <button
          type="button"
          id="btn-export-csv"
          class="w-full py-3 rounded-lg border border-border-strong text-sm font-semibold text-text-secondary hover:border-primary hover:text-text hover:bg-primary-lighter transition flex items-center justify-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Export results as CSV
        </button>

        <!-- ===== CTA 1 — Conditional, shows when LTV:CAC < 3 ===== -->
        <div id="cta-low-ltvcac" class="embed-hide hidden bg-primary-lighter border border-primary rounded-xl p-6">
          <p class="text-xs text-primary uppercase tracking-widest font-mono mb-2 font-semibold">
            ⚠ Recommended next step
          </p>
          <h3 class="text-lg font-bold text-text mb-2">Looking for the Right CRM?</h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-4">
            The right CRM can cut your CAC by 30–40% and boost LTV through better retention.
            See how the top 3 CRMs compare on pricing, features, and scalability.
          </p>
          <a
            href="/crm/salesforce-vs-hubspot-vs-pipedrive/"
            class="inline-block px-5 py-2.5 rounded-lg font-semibold text-sm transition"
            style="background-color: var(--color-primary-dark); color: #ffffff;"
          >
            Compare Top 3 CRMs →
          </a>
        </div>
      </section>
    </div>

    <!-- ===== How You Compare — Benchmark card ===== -->
    <section class="mb-12">
      <div class="bg-surface border border-border rounded-xl overflow-hidden">
        <div class="px-6 py-5 border-b border-border bg-bg-alt">
          <p class="text-xs text-text-muted uppercase tracking-widest font-mono mb-1">
            How You Compare
          </p>
          <h2 class="text-xl md:text-2xl font-bold text-text">Your numbers and illustrative planning ranges</h2>
          <p class="text-xs text-text-muted mt-1">
            These ranges are planning aids, not audited industry benchmarks or investment advice.
            The classification updates as you change the inputs.
          </p>
        </div>

        <!-- 5 benchmark rows, populated by JS -->
        <div id="benchmark-rows">
          {BENCHMARKS.map((b) => (
            <div class="benchmark-row px-6 py-5 border-b border-border last:border-b-0" data-bench-id={b.id}>
              <div class="flex flex-col md:flex-row md:items-start md:gap-6">
                <!-- Left: indicator + your value + tier label -->
                <div class="md:w-[280px] mb-3 md:mb-0">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-xs text-text-muted font-mono uppercase tracking-wide">
                      {b.label}
                    </span>
                  </div>
                  <p class="bench-value text-lg font-bold font-mono text-text mb-1" data-bench-value>—</p>
                  <span class="bench-tier-label inline-block text-xs font-semibold px-2.5 py-1 rounded-full" data-bench-tier>
                    —
                  </span>
                </div>
                <!-- Right: benchmark text + source link -->
                <div class="flex-1">
                  <p class="text-sm text-text-secondary leading-relaxed mb-2">{b.text}</p>
                  <a
                    href={b.sourceUrl}
                    class="inline-flex items-center gap-1 text-xs font-semibold text-primary hover:underline"
                  >
                    Source: {b.sourceLabel}
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- ===== CTA 2 — Static, always shown at bottom of benchmark card ===== -->
        <div class="embed-hide px-6 py-5 bg-bg-alt border-t border-border flex flex-col md:flex-row md:items-center md:justify-between gap-3">
          <div>
            <h3 class="text-base font-bold text-text mb-1">Get Detailed Pricing Breakdown</h3>
            <p class="text-sm text-text-muted">
              See how top SaaS tools stack up on pricing, features, and value — updated for 2026.
            </p>
          </div>
          <a
            href="/crm/best-crm-small-business/"
            class="shrink-0 px-5 py-2.5 rounded-lg border border-border-strong text-sm font-semibold text-text-secondary hover:border-primary hover:text-text hover:bg-primary-lighter transition whitespace-nowrap"
          >
            See Best CRM Software →
          </a>
        </div>
      </div>
    </section>

    <!-- ===== How to use ===== -->
    <section class="embed-hide bg-surface-elevated border border-border rounded-xl p-6 md:p-8 mb-12 max-w-3xl mx-auto">
      <h2 class="text-xl font-bold text-text mb-4">How to use this calculator</h2>
      <ol class="list-decimal pl-6 space-y-2 text-text-secondary text-sm leading-relaxed">
        <li>
          <strong class="text-text">Enter your current numbers</strong> — your real MRR, customer count, and churn rate.
          Don't guess; pull from Stripe / your billing system.
        </li>
        <li>
          <strong class="text-text">Estimate your CAC</strong> by dividing total sales + marketing spend (last 90 days)
          by the number of new customers acquired in the same period.
        </li>
        <li>
          <strong class="text-text">Set your growth rate</strong> based on the last 3 months — average net MRR added per month
          divided by starting MRR.
        </li>
        <li>
          <strong class="text-text">Watch the metrics update.</strong> Use the range hints to compare
          scenarios without treating them as universal performance standards.
        </li>
      </ol>
    </section>

    <!-- ===== What the numbers mean ===== -->
    <section class="embed-hide prose prose-invert max-w-3xl mx-auto mb-12">
      <h2 class="text-2xl font-bold text-text mb-4">What the numbers mean</h2>

      <h3 class="text-lg font-bold text-text mt-6 mb-2">ARR (Annual Recurring Revenue)</h3>
      <p class="text-text-secondary text-sm leading-relaxed">
        Your monthly recurring revenue annualized. ARR is a useful scale measure, but it does not show margin, retention, cash flow, or valuation by itself.
      </p>

      <h3 class="text-lg font-bold text-text mt-6 mb-2">LTV : CAC ratio</h3>
      <p class="text-text-secondary text-sm leading-relaxed">
        How much customer revenue you earn over the customer's lifetime, divided by what it cost to acquire them.
        A 3:1 ratio is often used as a planning convention, but the right target depends on gross margin,
        cash timing, retention, and how lifetime value is estimated.
      </p>

      <h3 class="text-lg font-bold text-text mt-6 mb-2">Payback Period</h3>
      <p class="text-text-secondary text-sm leading-relaxed">
        How many months it takes for a single customer's revenue to repay your acquisition cost.
        Use the result to compare scenarios. The sustainable period depends on margin, cash availability,
        retention, contract timing, and customer segment.
      </p>

      <h3 class="text-lg font-bold text-text mt-6 mb-2">Customer Lifetime</h3>
      <p class="text-text-secondary text-sm leading-relaxed">
        The expected duration a customer stays with you. Calculated as <code class="text-xs">1 / monthly churn rate</code>.
        A 3% monthly churn implies ~33 month average lifetime.
      </p>
    </section>

    <!-- ===== CTA 3 — Bottom banner: internal CRM resources ===== -->
    <section class="embed-hide mb-12">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- CRM comparison -->
        <div class="bg-surface border border-border rounded-xl p-6 hover:border-primary transition">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-mono uppercase tracking-wide text-text-muted">Guide</span>
            <span class="text-xs px-2 py-0.5 rounded bg-primary-lighter text-primary font-semibold">CRM COMPARISON</span>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Compare Salesforce, HubSpot, and Pipedrive</h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-4">
            See how three popular CRM platforms compare on pricing, pipeline management, automation,
            reporting, and fit by team size.
          </p>
          <a
            href="/crm/salesforce-vs-hubspot-vs-pipedrive/"
            class="inline-block px-5 py-2.5 rounded-lg font-semibold text-sm transition"
            style="background-color: var(--color-primary-dark); color: #ffffff;"
            data-internal-cta="crm-comparison"
          >
            Compare CRM Platforms →
          </a>
        </div>

        <!-- Best CRM guide -->
        <div class="bg-surface border border-border rounded-xl p-6 hover:border-primary transition">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-mono uppercase tracking-wide text-text-muted">Guide</span>
