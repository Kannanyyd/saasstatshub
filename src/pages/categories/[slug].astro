---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import CoverImage from '../../components/CoverImage.astro';
import '../../styles/global.css';
import { getCategoryPageData, getHomePageData, type CategoryPageData, type Category } from '../../lib/wp-api';
import { mockCategoryData, mockHomePageData } from '../../data/mock-data';
import { metaFor, CATEGORIES } from '../../lib/constants';

export async function getStaticPaths() {
  // Fetch the canonical category list once; pass it to each page as props
  // so every category page renders an accurate sidebar without re-querying.
  let allCats: Category[];
  try {
    allCats = (await getHomePageData()).categories;
  } catch {
    allCats = mockHomePageData.categories;
  }

  // Only generate pages for categories we know about (matches lib/constants.ts).
  // This keeps URLs predictable and avoids drift between WP and the frontend.
  const knownSlugs = new Set(CATEGORIES.map((c) => c.slug));
  const targets = allCats.filter((c) => knownSlugs.has(c.slug));

  return targets.map((c) => ({
    params: { slug: c.slug },
    props: { allCats },
  }));
}

interface PageProps {
  allCats: Category[];
}

const { slug } = Astro.params;
const { allCats } = Astro.props as PageProps;

let data: CategoryPageData;
try {
  data = await getCategoryPageData(slug!);
} catch {
  data = mockCategoryData[slug!] || {
    category: mockHomePageData.categories.find((c) => c.slug === slug) || { id: '0', name: slug!, slug: slug!, count: 0, description: '' },
    articles: [],
    hasNextPage: false,
    endCursor: '',
  };
}

const { category, articles } = data;
const meta = metaFor(category.name, category.slug);

// Breadcrumb schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://saasstatshub.com/" },
    { "@type": "ListItem", position: 2, name: category.name },
  ],
};
---

<BaseLayout title={`${category.name} Statistics`} description={category.description || `Latest ${category.name} statistics, market data, and trends.`} canonicalURL={new URL(Astro.url.pathname, Astro.site).href}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Category Hero -->
  <section class="relative overflow-hidden" style={`background: linear-gradient(135deg, ${meta.color}10 0%, ${meta.colorEnd}08 100%);`}>
    <div class="absolute inset-0 bg-tech-grid-fine opacity-60"></div>
    <div class="absolute -top-10 right-[-5%] w-72 h-72 rounded-full blur-[100px]" style={`background: ${meta.color}26;`}></div>
    <div class="relative max-w-[1200px] mx-auto px-6 py-10 md:py-14">
      <!-- Breadcrumb -->
      <nav class="breadcrumb mb-6" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span class="text-text-secondary">{category.name}</span>
      </nav>

      <div class="flex items-center gap-4 mb-4">
        <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl" style={`background: ${meta.bg};`}>
          {meta.emoji}
        </div>
        <div>
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">{category.name} Statistics</h1>
          <p class="text-text-secondary mt-1">{category.description}</p>
        </div>
      </div>
      <div class="flex items-center gap-3 text-sm text-text-muted mt-2">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full font-semibold" style={`background: ${meta.bg}; color: ${meta.color};`}>
          {category.count} articles
        </span>
      </div>
    </div>
  </section>

  <div class="max-w-[1200px] mx-auto px-6 py-8">
    <div class="flex gap-8">
      <!-- Article List -->
      <div class="flex-1 min-w-0">
        <div class="space-y-5">
          {articles.length > 0 ? articles.map((article) => (
            <article class="article-card group flex gap-5 p-4">
              <div class="hidden sm:block w-48 h-32 shrink-0 rounded-lg overflow-hidden card-image">
                {article.image ? (
                  <img src={article.image} alt={article.imageAlt} class="w-full h-full object-cover" loading="lazy" />
                ) : (
                  <CoverImage title={article.title} category={article.category.name} />
                )}
              </div>
              <div class="flex-1 flex flex-col justify-center card-body">
                <a href={`/categories/${article.category.slug}/`} class="text-xs font-bold uppercase tracking-wider text-primary mb-1.5 font-mono">{article.category.name}</a>
                <h3 class="font-bold text-lg leading-snug mb-1.5">
                  <a href={`/${article.category.slug}/${article.slug}/`} class="text-text hover:text-primary transition-colors no-underline">{article.title}</a>
                </h3>
                <p class="text-sm text-text-secondary line-clamp-2 mb-2">{article.excerpt}</p>
                <div class="flex items-center gap-3 text-xs text-text-muted font-mono">
                  <span>{article.date}</span>
                  <span>·</span>
                  <span>{article.readTime} min read</span>
                </div>
              </div>
            </article>
          )) : (
            <div class="text-center py-16">
              <div class="text-5xl mb-4">📭</div>
              <p class="text-text-secondary text-lg">No articles yet in this category</p>
              <p class="text-text-muted text-sm mt-2">Check back soon — we're always adding new data!</p>
            </div>
          )}
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="hidden md:block w-[300px] shrink-0">
        <div class="sticky top-20 space-y-5">
          <!-- Categories Nav -->
          <div class="border border-border rounded-xl p-5 bg-white">
            <h3 class="font-bold text-sm uppercase tracking-wider text-text-muted mb-3">📂 Categories</h3>
            <ul class="space-y-1">
              {allCats.map((cat) => {
                const cm = metaFor(cat.name, cat.slug);
                return (
                  <li>
                    <a href={`/categories/${cat.slug}/`} class:list={['flex items-center gap-2 text-sm px-3 py-2 rounded-lg transition-colors', cat.slug === category.slug ? 'bg-primary-lighter text-primary font-semibold' : 'text-text-secondary hover:text-primary hover:bg-bg-alt']}>
                      <span class="text-base">{cm.emoji}</span>
                      {cat.name}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>

          <!-- Newsletter -->
          <div class="rounded-xl overflow-hidden" style="background: linear-gradient(135deg, #1E40AF, #2563EB);">
            <div class="p-5">
              <h3 class="font-bold text-white mb-1.5">📧 Weekly SaaS Digest</h3>
              <p class="text-sm text-blue-200/70 mb-4">Get the latest stats in your inbox.</p>
              <input type="email" placeholder="you@email.com" class="w-full px-3 py-2 rounded-lg bg-white/10 border border-white/15 text-sm text-white placeholder-blue-300/40 focus:outline-none focus:border-white/30 mb-2" />
              <button class="w-full px-3 py-2.5 rounded-lg font-semibold text-sm text-primary bg-white hover:bg-blue-50 transition-colors">Subscribe</button>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
