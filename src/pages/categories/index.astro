---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import '../../styles/global.css';
import { getAllCategories, type Category } from '../../lib/wp-api';
import { mockHomePageData } from '../../data/mock-data';
import { CATEGORIES } from '../../lib/constants';

// Pull WP categories with counts. Fall back to constants if WP is unreachable.
let wpCategories: Category[];
try {
  wpCategories = await getAllCategories();
} catch {
  wpCategories = mockHomePageData.categories;
}

// Merge WP counts with the canonical metadata in constants.ts so each card
// has the right icon/color/description even if WP returns a stub.
const knownSlugs = new Set(CATEGORIES.map((c) => c.slug));
const categoryCards = CATEGORIES.map((meta) => {
  const fromWP = wpCategories.find((c) => c.slug === meta.slug);
  return {
    ...meta,
    count: fromWP?.count ?? 0,
  };
}).filter((c) => knownSlugs.has(c.slug));

const title = 'All Categories';
const description = 'Browse SaaS statistics by category across CRM, marketing, e-commerce, AI, security, healthcare, legal tech, education, real estate, and more. 850+ in-depth statistics articles for 2026.';
---

<BaseLayout title={title} description={description}>
  <section class="max-w-[1200px] mx-auto px-6 py-12 md:py-16">
    <div class="mb-10">
      <p class="text-xs text-text-muted uppercase tracking-widest font-mono mb-2">All Categories</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-3">Browse SaaS Statistics by Category</h1>
      <p class="text-text-secondary max-w-2xl">
        850+ in-depth statistics articles covering 22 major SaaS and technology categories.
        Each article includes Quick Overview tables, key takeaways, and cited sources.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {categoryCards.map((cat) => (
        <a
          href={`/categories/${cat.slug}/`}
          class="article-card group block p-6 rounded-xl border border-border bg-surface hover:border-primary transition no-underline"
        >
          <div class="flex items-start justify-between mb-3">
            <div
              class="w-12 h-12 rounded-lg inline-flex items-center justify-center"
              style={`background: ${cat.color}22; color: ${cat.color};`}
            >
              <Icon name={cat.iconName} aria-hidden="true" class="w-6 h-6" />
            </div>
            <span class="text-xs px-2 py-0.5 rounded bg-bg-alt text-text-secondary font-mono">
              {cat.count} {cat.count === 1 ? 'article' : 'articles'}
            </span>
          </div>
          <h2 class="text-xl font-bold mb-2 group-hover:text-primary transition" style="color: var(--color-text);">
            {cat.name}
          </h2>
          <p class="text-sm text-text-secondary leading-relaxed">
            {cat.desc}
          </p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
