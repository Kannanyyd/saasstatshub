# Cloudflare Pages custom headers.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/
#
# Rules are matched top-to-bottom; the FIRST matching rule per header wins,
# but Pages MERGES headers across all matching rules. More specific paths
# should appear before broader ones. Static, content-hashed assets get a
# 1-year immutable cache; dynamic API routes are never cached.

# ----------------------------------------------------------------------------
# Content-hashed build assets (/_astro/global.C0af3f4e.css etc.)
# Filenames change whenever content changes, so they're safe to cache forever.
# ----------------------------------------------------------------------------
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# ----------------------------------------------------------------------------
# Self-hosted fonts — also fingerprinted / stable, cache for a year.
# ----------------------------------------------------------------------------
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# ----------------------------------------------------------------------------
# Static images and icons. These filenames are stable (not hashed) so use a
# moderate TTL with revalidation rather than immutable, in case we replace one.
# ----------------------------------------------------------------------------
/*.svg
  Cache-Control: public, max-age=604800
/*.ico
  Cache-Control: public, max-age=604800
/*.png
  Cache-Control: public, max-age=604800
/*.jpg
  Cache-Control: public, max-age=604800
/*.webp
  Cache-Control: public, max-age=604800
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# ----------------------------------------------------------------------------
# Pagefind search index — regenerated on every build. Short TTL so search
# results stay fresh after a content update, but still cacheable per session.
# ----------------------------------------------------------------------------
/pagefind/*
  Cache-Control: public, max-age=3600

# ----------------------------------------------------------------------------
# API routes (Cloudflare Pages Functions, e.g. /api/subscribe).
# MUST NOT be cached — these are dynamic POST endpoints.
# ----------------------------------------------------------------------------
/api/*
  Cache-Control: no-store, no-cache, must-revalidate
  X-Robots-Tag: noindex

# ----------------------------------------------------------------------------
# Security headers for every HTML document.
# (Static HTML keeps Pages' default short TTL so content edits go live fast;
#  we don't force a long HTML cache to avoid serving stale articles.)
# ----------------------------------------------------------------------------
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=()
