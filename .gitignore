# Build output
dist/
# Astro generated types and cache
.astro/

# Dependencies
node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Environment variables
.env
.env.local
.env.production
.env.*.local

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
Thumbs.db

# Cloudflare Wrangler local state
.wrangler/

# Temporary files used for ad-hoc GraphQL probing
.tmp-*
*.tmp.json

# Test coverage
coverage/

# Pre-phase baseline artifacts (large Lighthouse reports + raw HTML snapshots).
# Keep BASELINE.md tracked, ignore the bulk artifacts.
baseline/baseline-*.html
baseline/baseline-*.json
baseline/lh-*.report.json
baseline/lh-*.report.html
page-css3.css
page-css*.css

# Local commit-message scratch files (used by the agent to build multi-line
# commit messages without escaping issues; never meant to be tracked).
baseline/.commit-msg-*.tmp
.commit-msg-*.tmp

# Archived Lighthouse reports and historical snapshots (large binary-like JSON/HTML).
# Active verify-*.mjs scripts stay tracked; these archives are reference-only.
baseline/archive-lighthouse-reports/
baseline/archive-snapshots/

# Temporary HTML files from production curl probes
tmp-*.html
